  "questions": [
    {
      "id": "Q01",
      "source": "manus_Q0001",
      "text": "You have one hour of free time. Do you:",
      "type": "this_or_that",
      "answers": [
        { "text": "Read the rulebook for a heavy strategy game.", "weights": { "PSY_CONSCIENTIOUSNESS": 1.0, "MEC_COMPLEXITY": 1.0 } },
        { "text": "Play three quick rounds of a loud party game.", "weights": { "PSY_EXTRAVERSION": 1.0, "CTX_TIME": -1.0 } }
      ]
    },
    {
      "id": "Q02",
      "source": "manus_Q0002",
      "text": "In a cooperative game, the group is about to make a fatal mistake. You know the optimal move. Do you:",
      "type": "this_or_that",
      "answers": [
        { "text": "Take charge and tell everyone exactly what to do.", "weights": { "PSY_ACHIEVEMENT": 1.0, "PSY_AGREEABLENESS": -0.5 } },
        { "text": "Let the group make the mistake so everyone feels involved.", "weights": { "PSY_SOCIAL": 1.0, "PSY_AGREEABLENESS": 1.0 } }
      ]
    },
    {
      "id": "Q03",
      "source": "manus_Q0003",
      "text": "What's the best part of winning?",
      "type": "this_or_that",
      "answers": [
        { "text": "Knowing my strategy was mathematically superior.", "weights": { "PSY_ACHIEVEMENT": 1.0, "MEC_STRATEGY": 1.0 } },
        { "text": "Seeing the look of despair on my friend's face.", "weights": { "PSY_KILLER": 1.0, "SOC_DIRECT_INDIRECT": 1.0 } }
      ]
    },
    {
      "id": "Q04",
      "source": "manus_Q0004",
      "text": "You discover a broken, overpowered combo in a game. Do you:",
      "type": "this_or_that",
      "answers": [
        { "text": "Exploit it mercilessly to crush your opponents.", "weights": { "PSY_KILLER": 1.0, "PSY_ACHIEVEMENT": 0.5 } },
        { "text": "Point it out to the table and agree not to use it.", "weights": { "PSY_AGREEABLENESS": 1.0, "SOC_COOP_COMP": -0.5 } }
      ]
    },
    {
      "id": "Q05",
      "source": "manus_Q0005",
      "text": "A game requires you to lie to your partner's face. How do you feel?",
      "type": "this_or_that",
      "answers": [
        { "text": "Thrilled. I'm a master of deception.", "weights": { "SOC_TRUST_BETRAYAL": 1.0, "PSY_EXTRAVERSION": 0.5 } },
        { "text": "Anxious. I hate deceiving people I care about.", "weights": { "SOC_TRUST_BETRAYAL": -1.0, "PSY_AGREEABLENESS": 1.0 } }
      ]
    },
