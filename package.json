{
  "name": "afterroar",
  "version": "0.1.0",
  "private": true,
  "description": "Afterroar platform monorepo — Store Ops (apps/ops) and Passport (apps/me) on top of shared packages (database, auth, types, ui). See CLAUDE.md and docs/.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @afterroar/ops",
    "dev:me": "npm run dev -w @afterroar/me",
    "build": "npm run build -w @afterroar/ops",
    "build:me": "npm run build -w @afterroar/me",
    "start": "npm run start -w @afterroar/ops",
    "lint": "npm run lint -w @afterroar/ops",
    "test": "npm run test -w @afterroar/ops",
    "db:generate": "npm run generate -w @afterroar/database"
  },
  "engines": {
    "node": ">=20"
  }
}
