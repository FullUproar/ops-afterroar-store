generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// HQ-OWNED: User table (READ-ONLY from Store Ops)
// Must match HQ's User model. Store Ops never writes to this.
// Only fields Store Ops needs are declared here.
// ============================================================
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  displayName       String?
  username          String?   @unique
  avatarUrl         String?
  passwordHash      String?
  passportCode      String?   @unique @db.VarChar(8)
  membershipTier    String    @default("FREE")
  gameLibrary       String?
  /// Standard NextAuth/email-verification timestamp. Set when the user clicks
  /// the verification link, OR when an OAuth provider that asserts a verified
  /// email (Google with email_verified=true) signs them in.
  emailVerified     DateTime?
  /// KYC-grade identity verification (Persona, ID.me) — separate from email.
  identityVerified  Boolean   @default(false)
  reputationScore   Int       @default(100)
  isFrozen          Boolean   @default(false)
  marketingConsent  Boolean   @default(false)
  /// Date of birth. Required for new signups (collected via neutral age screen).
  /// Used to gate <13 (block), 13-17 (parental consent path), 18+ (standard).
  /// Nullable to allow legacy users created before age-gating shipped.
  dateOfBirth       DateTime?
  /// Denormalized snapshot of (dateOfBirth → age < 18). Set at signup, flipped
  /// to false by daily cron on 18th birthday. Avoids recomputing from DOB on
  /// every visibility/discovery query. Source of truth is dateOfBirth.
  isMinor           Boolean   @default(false)
  /// Default profile visibility for the user. "circle" is the most restrictive
  /// (visible only to approved Circle members). Minor accounts default to
  /// "circle" per privacy-by-default policy. Adults default to "public".
  defaultVisibility String    @default("public")
  /// Set on minor accounts: links to the verified parent who consented to
  /// the account. Null for adults. If parent deletes their account, the
  /// minor's account cascades to deletion. If parent revokes consent in
  /// settings, the minor's account deactivates (accountStatus flip).
  parentUserId      String?
  /// Timestamp when the parental consent flow completed for this minor account
  /// (parent verified + consent fee paid OR Pro active + attestation signed).
  /// Null until activation; used to keep an audit trail of when consent was
  /// given.
  parentVerifiedAt  DateTime?
  /// Monitoring opt-in state. When true, the parent can see this minor
  /// account's activity (RSVPs, connections, photos, alerts) on their
  /// /parent-dashboard. Requires the parent to be on Pro tier — toggling
  /// off Pro turns this off. Kid sees a "Supervised by [parent]" badge on
  /// their own profile when this is true (transparency, not stealth).
  /// Always false on adult accounts.
  monitoringEnabled Boolean   @default(false)
  /// Lifecycle: "active" | "pending_parent" | "paused" | "suspended". Minor
  /// accounts start "pending_parent" and flip to "active" only after parent
  /// completes consent. If parent's Pro lapses, kid flips to "paused" until
  /// renewal.
  accountStatus     String    @default("active")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  parent   User?  @relation("ParentChild", fields: [parentUserId], references: [id])
  children User[] @relation("ParentChild")

  pos_staff               PosStaff[]
  accounts                Account[]
  consents                UserConsent[]
  pointsLedger            PointsLedger[]
  activities              UserActivity[]
  playRecords             PlayRecord[]          @relation("PlayRecords")
  gameLoans               GameLoan[]
  wishlistItems           WishlistItem[]
  createdTags             GameTag[]
  badges                  UserBadge[]
  entityMemberships       EntityMember[]
  entityConsents          EntityConsent[]
  entityClaims            EntityClaim[]
  apiKeys                 ApiKey[]
  paired_register_devices RegisterDevice[]
  generated_pairing_codes RegisterPairingCode[]
  parentConsentRequests   MinorConsentRequest[] @relation("MinorRequester")
  parentConsentApprovals  MinorConsentRequest[] @relation("ParentApprover")
  parentAlerts            MonitoredAlert[]      @relation("ParentAlerts")
  childAlerts             MonitoredAlert[]      @relation("ChildAlerts")
  adminAuditActions       AdminAuditLog[]       @relation("AdminAuditActions")

  @@index([parentUserId])
  @@index([isMinor])
  @@index([accountStatus])
  @@map("User")
}

/// Waitlist for users who attempted signup at 13-17 but didn't complete
/// parental consent (or the feature flag turned consent off and we still
/// want to capture intent). Stored separately from User to avoid creating
/// shadow accounts. notifyAfter = computed 18th birthday from stated DOB
/// (DOB itself is NOT stored to minimize PII on minors).
///
/// Two flush triggers:
///   1) Daily cron emails anyone whose notifyAfter <= today: "you can sign up now"
///   2) On launch of <18 support: blast everyone with "we're ready for you"
model MinorWaitlist {
  id              String    @id @default(cuid())
  email           String
  parentEmail     String?
  notifyAfter     DateTime
  attemptedAt     DateTime  @default(now())
  notifiedAt      DateTime?
  /// Set when this person eventually does sign up; lets us prove conversion.
  convertedUserId String?
  source          String    @default("signup")

  @@index([email])
  @@index([notifyAfter])
}

/// Tracks the parental consent flow for a 13-17 signup attempt. One row per
/// signup attempt. Lifecycle:
///   pending -> parent clicks magic link -> parent completes Persona + pays
///     consent fee (or starts Pro) + attest -> completed (kid activates)
///   pending -> token expires after 7 days -> expired
///   pending -> parent declines -> declined
///
/// We DO store the kid's stated DOB here briefly (so we can re-validate they
/// are 13-17 when the parent completes), but we do NOT persist it past
/// completion — once linked, the kid's User row holds the DOB.
///
/// `consentFeePaidAt`: tracks the one-time $5 consent fee that covers the
/// Persona verification cost. Either the parent pays this AND the
/// approve endpoint marks the kid active, OR the parent subscribes to Pro
/// (which bundles the consent fee in the first month). Both unlock kid
/// activation; only Pro unlocks the parent monitoring dashboard.
model MinorConsentRequest {
  id                 String    @id @default(cuid())
  /// Token for the parent's magic link. Random hex, ~32 chars.
  token              String    @unique
  /// The kid's email (the account-to-be).
  childEmail         String
  /// The kid's stated display name (for the parent's "your kid wants to sign up" email).
  childDisplayName   String?
  /// The kid's stated DOB. Cleared when the request completes or expires.
  childDateOfBirth   DateTime?
  /// The parent's email — where the magic link is sent.
  parentEmail        String
  /// Once the kid signs in to claim their pending account, this is set.
  childUserId        String?
  child              User?     @relation("MinorRequester", fields: [childUserId], references: [id])
  /// Once the parent completes verification, this is set.
  parentUserId       String?
  parent             User?     @relation("ParentApprover", fields: [parentUserId], references: [id])
  /// Lifecycle state.
  status             String    @default("pending")
  /// Free-text from the parent's attestation step (not legally required, but
  /// kept for audit if a guardianship dispute arises).
  attestationText    String?
  /// Set when the parent pays the one-time $5 consent fee. Mutually
  /// exclusive with the Pro path (Pro parents bundle the fee into their
  /// first month and don't need this set).
  consentFeePaidAt   DateTime?
  /// Whether the parent chose the Pro path during this consent flow.
  /// Used to set User.monitoringEnabled on the kid at activation time.
  parentChoseProPath Boolean   @default(false)
  createdAt          DateTime  @default(now())
  expiresAt          DateTime
  completedAt        DateTime?

  @@index([childEmail])
  @@index([parentEmail])
  @@index([status])
  @@index([expiresAt])
}

/// Append-only audit log of admin actions taken via /admin/* surfaces.
/// Every state-changing admin action (verify, unverify, ban, unban,
/// delete, update, create, resend) writes a row here with:
///   - which admin took the action (adminUserId — the User.id of the
///     allowlisted email that performed it)
///   - what was done (action — discriminator string like 'user.verify')
///   - what was acted on (targetType + targetId, free-form for now;
///     today only User but extensible)
///   - before/after state (Json snapshots — bounded to fields we
///     actually mutate; do NOT include passwordHash or DOB)
///   - request context (ip, userAgent) for forensics
/// Read-only via /admin/audit. Never deleted (retention policy TBD;
/// for now keep forever, revisit at scale).
model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  /// Action code: 'user.verify' | 'user.unverify' | 'user.ban' |
  /// 'user.unban' | 'user.delete' | 'user.update' | 'user.create' |
  /// 'user.resend_verification'. Free-form so future surfaces (venue
  /// admin, event admin) extend without schema migration.
  action      String
  targetType  String   @default("user")
  targetId    String?
  /// Snapshot of relevant fields BEFORE the action. Null for create.
  /// Sensitive fields (passwordHash, DOB) are explicitly omitted by
  /// the logging helper.
  beforeState Json?
  /// Snapshot AFTER the action. Null for delete.
  afterState  Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin User @relation("AdminAuditActions", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt])
}

/// Alerts surfaced on a parent's monitoring dashboard for activity on a
/// linked minor account. Created by background jobs that watch for
/// noteworthy events (new adult connection outside Circle, RSVP to
/// non-venue public event, etc.).
///
/// Privacy note: alerts contain METADATA only (event type, counterparty
/// name/email, timestamps). They do NOT contain message contents. The
/// monitoring dashboard is light-touch oversight, not surveillance.
model MonitoredAlert {
  id           String    @id @default(cuid())
  parentUserId String
  childUserId  String
  /// Type discriminator: 'new_adult_connection' | 'public_rsvp' |
  /// 'photo_upload' | 'circle_change' | etc. Free-form string for now;
  /// can promote to enum once the catalog stabilizes.
  alertType    String
  /// JSON metadata for the dashboard to render (counterparty info,
  /// event link, etc.). Schema varies by alertType.
  payload      Json
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  parent User @relation("ParentAlerts", fields: [parentUserId], references: [id], onDelete: Cascade)
  child  User @relation("ChildAlerts", fields: [childUserId], references: [id], onDelete: Cascade)

  @@index([parentUserId, readAt])
  @@index([childUserId])
  @@index([createdAt])
}

// ============================================================
// GAME TAG — Shared vocabulary for organizing collections.
// Like hashtags: anyone can create, popular ones gain meaning.
// ============================================================
// ============================================================
// PASSPORT BADGES — Portable identity markers. Native to Afterroar,
// also issuable by Full Uproar, stores, and other platform entities.
// ============================================================
// ============================================================
// AFTERROAR ENTITY � Canonical identity for stores, publishers,
// organizers, creators. Other apps (HQ, Store Ops) wrap with metadata.
// ============================================================
model AfterroarEntity {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  type         String    @default("store")
  /// Lifecycle: "unclaimed" (auto-imported from FLGS network DB, no owner
  /// has verified yet) → "pending" (claim submitted, awaiting verification)
  /// → "active" (claim verified, owner has access). "suspended" pulls the
  /// entity offline. Stored as string for flexibility — no DB enum.
  status       String    @default("pending")
  /// Nullable on unclaimed entities — bulk-imported FLGS data is often
  /// missing a public business email. The claim flow asks the claimant to
  /// provide one and uses that for verification email delivery.
  contactEmail String?
  contactName  String?
  contactPhone String?
  websiteUrl   String?
  logoUrl      String?
  description  String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?   @default("US")
  latitude     Float?
  longitude    Float?
  timezone     String?
  metadata     Json?     @default("{}")
  createdAt    DateTime  @default(now())
  approvedAt   DateTime?
  suspendedAt  DateTime?
  notes        String?

  members  EntityMember[]
  consents EntityConsent[]
  claims   EntityClaim[]

  @@index([type])
  @@index([status])
  @@index([city])
}

/// Audit + state for "I own this store, give me access" claim attempts.
/// One row per claim attempt; verified claims flip the entity to status=active
/// and create an EntityMember row with role=owner. Tokens are 64-char hex
/// strings sent via email; rotated on each new claim attempt for the same
/// entity to invalidate old links.
model EntityClaim {
  id             String    @id @default(cuid())
  entityId       String
  /// User initiating the claim (must be signed in to Passport).
  claimantUserId String
  /// Email the verification link was sent to. May differ from the user's
  /// primary email — e.g. owner uses owner@thestore.com to receive the link
  /// but is logged in as their personal Passport account.
  contactEmail   String
  contactName    String?
  contactPhone   String?
  /// Verification token (64 hex chars). Hashed at rest would be better for
  /// breach posture — leaving in plaintext for v1 to keep the link-redemption
  /// flow simple. Tokens expire 72h after creation; old tokens for the same
  /// entity are deleted when a new claim is initiated.
  token          String    @unique
  /// "pending" → "verified" → "rejected" / "expired".
  status         String    @default("pending")
  expiresAt      DateTime
  verifiedAt     DateTime?
  /// Free-form proof the claimant supplied (URLs, FEIN last 4, etc).
  /// Auto-verified if contactEmail's domain matches entity.websiteUrl.
  evidence       Json?     @default("{}")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  entity AfterroarEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [claimantUserId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([claimantUserId])
  @@index([status])
  @@index([token])
}

model EntityMember {
  id       String   @id @default(cuid())
  entityId String
  userId   String
  role     String   @default("member")
  addedAt  DateTime @default(now())
  addedBy  String?

  entity AfterroarEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
}

model EntityConsent {
  id        String    @id @default(cuid())
  userId    String
  entityId  String
  scopes    String[]
  grantedAt DateTime  @default(now())
  revokedAt DateTime?
  expiresAt DateTime?
  source    String?

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity AfterroarEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  action      String
  targetType  String?
  targetId    String?
  entityId    String?
  scopesUsed  String[]
  metadata    Json?    @default("{}")
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([targetId])
  @@index([entityId])
  @@index([createdAt])
}

model ShopifyConnection {
  id              String    @id @default(cuid())
  entityId        String    @unique
  shopDomain      String    @unique
  accessToken     String
  scopes          String
  shopName        String?
  shopEmail       String?
  currency        String?
  pointsPerDollar Int       @default(1)
  minOrderCents   Int       @default(0)
  active          Boolean   @default(true)
  installedAt     DateTime  @default(now())
  uninstalledAt   DateTime?
  lastWebhookAt   DateTime?
  metadata        Json?     @default("{}")

  @@index([entityId])
  @@index([shopDomain])
  @@index([active])
}

model ShopifyWebhookEvent {
  id          String    @id @default(cuid())
  shopDomain  String
  topic       String
  eventId     String
  orderId     String?
  payload     Json
  processedAt DateTime?
  result      String?
  pointsDelta Int?
  userId      String?
  createdAt   DateTime  @default(now())

  @@unique([shopDomain, topic, eventId])
  @@index([shopDomain])
  @@index([topic])
  @@index([orderId])
  @@index([createdAt])
}

model ShopifyOauthState {
  state      String   @id
  shopDomain String
  entityId   String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

model EntityConsentRequest {
  id              String    @id @default(cuid())
  token           String    @unique
  entityId        String
  requestedScopes String[]
  createdBy       String
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  claimedAt       DateTime?
  claimedByUserId String?
  note            String?

  @@index([entityId])
  @@index([token])
  @@index([expiresAt])
}

model PassportBadge {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  iconEmoji   String?
  iconUrl     String?
  color       String    @default("#FF8200")
  category    String    @default("general")
  issuerType  String    @default("afterroar")
  issuerName  String?
  issuerId    String?
  isLimited   Boolean   @default(false)
  totalIssued Int       @default(0)
  maxSupply   Int?
  createdAt   DateTime  @default(now())
  retiredAt   DateTime?

  userBadges UserBadge[]

  @@index([category])
  @@index([issuerType])
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeId   String
  issuedAt  DateTime  @default(now())
  issuedBy  String?
  reason    String?
  metadata  Json?     @default("{}")
  revokedAt DateTime?

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge PassportBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model GameTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  type      String   @default("custom")
  useCount  Int      @default(0)
  createdBy String?
  createdAt DateTime @default(now())
  creator   User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([type])
  @@index([useCount(sort: Desc)])
}

// ============================================================
// GAME LOAN — Track games lent to friends. User-owned data.
// "Who has my copy of Terraforming Mars?"
// ============================================================
model GameLoan {
  id              String    @id @default(cuid())
  userId          String
  gameTitle       String
  bggId           Int?
  borrowerName    String
  borrowerContact String?
  lentAt          DateTime  @default(now())
  dueDate         DateTime?
  returnedAt      DateTime?
  condition       String?
  notes           String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, returnedAt])
}

// ============================================================
// WISHLIST ITEM — Games the user wants. Portable across stores.
// Shareable with non-gaming family for gift-giving.
// ============================================================
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  gameTitle String
  bggId     Int?
  priority  Int      @default(3)
  notes     String?
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameTitle])
  @@index([userId])
}

// ============================================================
// USER CONSENT — Granular per-category consent for the Afterroar
// consent architecture. Mirrors the table created by
// full-uproar-site migration 2026-04-12.
// ============================================================
model UserConsent {
  id        String    @id @default(cuid())
  userId    String
  category  String
  granted   Boolean
  grantedAt DateTime?
  revokedAt DateTime?
  source    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@index([category])
}

// ============================================================
// POINTS LEDGER — Append-only ledger with running balance per store.
// Read view of the table owned by full-uproar-site. The afterroar
// app reads this to display points on the Passport.
// ============================================================
model PointsLedger {
  id          String    @id @default(cuid())
  userId      String
  storeId     String?
  amount      Int
  balance     Int
  action      String
  category    String
  description String
  metadata    String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, storeId])
  @@index([createdAt])
}

// ============================================================
// USER ACTIVITY — Activity log for check-ins, events, tournaments.
// Read view of the table owned by full-uproar-site.
// ============================================================
model UserActivity {
  id         Int      @id @default(autoincrement())
  userId     String
  action     String
  targetType String?
  targetId   Int?
  metadata   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, action])
}

// ============================================================
// PLAY RECORD — Canonical, portable per-player event history.
// Written by HQ (and future apps) via Connect API on match-lock.
// Read by Passport for the "competitive resume" surface and by
// other apps via the Connect API. The record survives even if
// HQ-side detail data is purged.
//
// Per the 2026-05-02 architecture lock:
//  - HQ owns operational state (Event, Round, Match) — the during-
//    event experience.
//  - Passport owns the portable record — what travels with the
//    player across apps and over time.
//
// "verified" = the host of the event has confirmed; "self_reported"
//   = the player added it themselves and the TO hasn't validated.
//   The UI must distinguish these so the resume claim isn't fraud
//   bait (per the 2026-05-02 honest-marketing decision).
// ============================================================
model PlayRecord {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("PlayRecords", fields: [userId], references: [id], onDelete: Cascade)

  // The remote event identity. eventId is HQ's GameNight.id (or
  // any future app that issues records). sourceApp lets us
  // distinguish "hq" vs "store_ops" vs "external_partner" without
  // collisions.
  sourceApp String   @default("hq")
  eventId   String // FK target lives in another DB — not enforced at SQL level
  eventName String // denormalized for display without round-trip
  eventDate DateTime
  venueId   String?
  venueName String?

  // What was played. Denormalized.
  gameTitle   String?
  bggId       Int?
  matchId     String? // HQ's Match.id — for back-reference
  roundNumber Int?

  // Result. Same shape as MatchParticipation on HQ.
  placement Int?
  score     Float?
  result    String? // 'win' | 'loss' | 'draw' | 'bye' | 'no_show'

  // Provenance. Critical for honest resume claims.
  source           String    @default("verified")
  // 'verified'      — host confirmed the result
  // 'self_reported' — player entered, no host validation
  // 'corroborated'  — other player(s) at the table agreed but no host validation
  verifiedByUserId String?
  verifiedAt       DateTime?

  recordedAt DateTime @default(now())

  @@index([userId, recordedAt])
  @@index([userId, sourceApp, eventId])
  @@index([eventId])
  @@index([source])
}

// ============================================================
// VENUE — The federated store directory. Read view of the table
// owned by full-uproar-site. Used for /stores on afterroar.me.
// ============================================================
model Venue {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  status           String   @default("unclaimed")
  email            String?
  phone            String?
  website          String?
  address          String?
  city             String?
  state            String?
  zip              String?
  lat              Float?
  lng              Float?
  venueType        String?
  googleRating     Float?
  reviewCount      Int?
  description      String?
  shortDescription String?
  logoUrl          String?
  coverImageUrl    String?
  hours            String?
  amenities        String?
  /// Origin + extras. Crowdsourced rows carry { crowdsourced: true,
  /// suggested_by_user_id, suggested_at }. Bulk-imported rows carry
  /// { source: 'flgs_network_import', imported_at }. Free-form so
  /// downstream tools can attach analytics + provenance without schema
  /// churn.
  metadata         Json?    @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([city, state])
}

// NextAuth required models — these tables already exist in the shared
// Neon DB (created by the full-uproar-site schema). Declared here so
// the Prisma client can query them for PrismaAdapter.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
