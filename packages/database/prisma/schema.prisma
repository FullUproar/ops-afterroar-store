// ============================================================
// POS TOURNAMENTS
// ============================================================
model PosTournament {
  id            String   @id @default(cuid())
  store_id      String
  event_id      String?
  name          String
  format        String?
  status        String   @default("registration")
  bracket_type  String   @default("single_elimination")
  max_players   Int?
  current_round Int      @default(0)
  total_rounds  Int?
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @default(now()) @db.Timestamptz()

  store   PosStore              @relation(fields: [store_id], references: [id], onDelete: Cascade)
  event   PosEvent?             @relation(fields: [event_id], references: [id])
  players PosTournamentPlayer[]
  matches PosTournamentMatch[]

  @@index([store_id])
  @@index([event_id])
  @@map("pos_tournaments")
}

model PosTournamentPlayer {
  id            String   @id @default(cuid())
  tournament_id String
  customer_id   String?
  player_name   String
  seed          Int?
  wins          Int      @default(0)
  losses        Int      @default(0)
  draws         Int      @default(0)
  dropped       Boolean  @default(false)
  standing      Int?
  created_at    DateTime @default(now()) @db.Timestamptz()

  tournament      PosTournament       @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  customer        PosCustomer?        @relation(fields: [customer_id], references: [id])
  matches_as_p1   PosTournamentMatch[] @relation("MatchPlayer1")
  matches_as_p2   PosTournamentMatch[] @relation("MatchPlayer2")
  matches_won     PosTournamentMatch[] @relation("MatchWinner")

  @@map("pos_tournament_players")
}

model PosTournamentMatch {
  id            String   @id @default(cuid())
  tournament_id String
  round_number  Int
  match_number  Int
  player1_id    String?
  player2_id    String?
  winner_id     String?
  player1_score Int      @default(0)
  player2_score Int      @default(0)
  status        String   @default("pending")
  table_number  String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  tournament PosTournament        @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  player1    PosTournamentPlayer? @relation("MatchPlayer1", fields: [player1_id], references: [id])
  player2    PosTournamentPlayer? @relation("MatchPlayer2", fields: [player2_id], references: [id])
  winner     PosTournamentPlayer? @relation("MatchWinner", fields: [winner_id], references: [id])

  @@map("pos_tournament_matches")
}

// ============================================================
// POS CATALOG: Federated Product Catalog
// ============================================================
model PosCatalogProduct {
  id                    String   @id @default(cuid())
  name                  String
  category              String
  subcategory           String?
  game                  String?
  product_type          String?
  set_name              String?
  set_code              String?
  attributes            Json     @default("{}")
  external_ids          Json     @default("{}")
  image_url             String?
  description           String?
  contributed_by_store_id String?
  verified              Boolean  @default(false)
  created_at            DateTime @default(now()) @db.Timestamptz()
  updated_at            DateTime @default(now()) @db.Timestamptz()

  // Scryfall bulk sync fields
  oracle_id             String?
  scryfall_id           String?
  mana_cost             String?
  type_line             String?
  oracle_text           String?
  keywords              String?  // comma-separated
  color_identity        String?  // comma-separated: W,U,B,R,G
  cmc                   Decimal? @db.Decimal(4, 1)
  rarity                String?
  legalities            Json?
  prices                Json?
  image_uri             String?
  last_synced_at        DateTime? @db.Timestamptz()

  // Universal product metadata (shared across network)
  publisher             String?
  distributor           String?
  release_year          Int?
  msrp_cents            Int?
  bgg_id                String?   // BoardGameGeek ID
  bgg_rating            Decimal?  @db.Decimal(3, 1)
  bgg_weight            Decimal?  @db.Decimal(3, 2)
  min_players           Int?
  max_players           Int?
  min_play_time         Int?      // minutes
  max_play_time         Int?
  min_age               Int?
  mechanics             String?   // comma-separated
  themes                String?   // comma-separated

  // Sealed product fields
  contents_description  String?   // e.g., "36 packs, 15 cards per pack"
  cards_per_pack        Int?
  packs_per_box         Int?

  inventory_items PosInventoryItem[]
  pricing         PosCatalogPricing[]

  @@index([category])
  @@index([game])
  @@index([oracle_id])
  @@index([scryfall_id])
  @@index([bgg_id])
  @@map("pos_catalog_products")
}

model PosCatalogCategory {
  id            String   @id @default(cuid())
  name          String
  slug          String
  parent_id     String?
  icon          String?
  sort_order    Int      @default(0)
  level         Int      @default(0)
  product_count Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz()

  parent   PosCatalogCategory?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children PosCatalogCategory[] @relation("CategoryTree")

  @@index([parent_id])
  @@index([slug])
  @@map("pos_catalog_categories")
}

model PosCatalogPricing {
  id                   String    @id @default(cuid())
  catalog_product_id   String
  store_id             String
  last_sale_price_cents Int?
  last_sale_date       DateTime? @db.Timestamptz()
  avg_sale_price_cents Int?
  velocity_per_week    Decimal   @default(0) @db.Decimal(10, 2)
  updated_at           DateTime  @default(now()) @db.Timestamptz()

  catalog_product PosCatalogProduct @relation(fields: [catalog_product_id], references: [id], onDelete: Cascade)
  store           PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([catalog_product_id, store_id])
  @@map("pos_catalog_pricing")
}

// ============================================================
// POS ORDERS (shipping & fulfillment)
// ============================================================
model PosOrder {
  id                 String    @id @default(cuid())
  store_id           String
  customer_id        String?
  order_number       String
  source             String    @default("pos") // pos, online, phone, shopify
  status             String    @default("pending") // pending, processing, shipped, delivered, cancelled
  fulfillment_status String    @default("unfulfilled") // unfulfilled, picking, packed, shipped, delivered
  fulfillment_type   String    @default("merchant") // merchant, pod, 3pl
  subtotal_cents     Int       @default(0)
  tax_cents          Int       @default(0)
  shipping_cents     Int       @default(0)
  discount_cents     Int       @default(0)
  total_cents        Int       @default(0)
  shipping_method    String?
  shipping_carrier   String?
  shipping_address   Json?
  tracking_number    String?
  tracking_url       String?
  label_url          String?
  weight_oz          Int?
  ship_date          DateTime? @db.Timestamptz()
  estimated_delivery DateTime? @db.Timestamptz()
  notes              String?
  ledger_entry_id    String?
  fulfilled_at       DateTime? @db.Timestamptz()
  shipped_at         DateTime? @db.Timestamptz()
  delivered_at       DateTime? @db.Timestamptz()
  created_at         DateTime  @default(now()) @db.Timestamptz()
  updated_at         DateTime  @default(now()) @db.Timestamptz()

  store           PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer        PosCustomer?      @relation(fields: [customer_id], references: [id])
  items           PosOrderItem[]
  shipping_labels PosShippingLabel[]

  @@index([store_id])
  @@index([store_id, status])
  @@index([store_id, fulfillment_status])
  @@index([order_number])
  @@map("pos_orders")
}

model PosOrderItem {
  id                String   @id @default(cuid())
  order_id          String
  inventory_item_id String?
  name              String
  quantity          Int      @default(1)
  price_cents       Int
  total_cents       Int
  fulfilled            Boolean  @default(false)
  fulfillment_type     String   @default("merchant") // merchant, pod, 3pl
  fulfillment_provider String?  // e.g. "printful", "shipbob"
  created_at           DateTime @default(now()) @db.Timestamptz()

  order          PosOrder          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@index([order_id])
  @@map("pos_order_items")
}

model PosShippingLabel {
  id                      String    @id @default(cuid())
  store_id                String
  order_id                String
  shipstation_shipment_id String?
  carrier_code            String
  service_code            String
  tracking_number         String?
  tracking_url            String?
  label_data              String?   // base64 PDF
  label_format            String    @default("pdf")
  shipment_cost_cents     Int       @default(0)
  other_cost_cents        Int       @default(0)
  weight_oz               Int?
  length_in               Decimal?  @db.Decimal(5, 1)
  width_in                Decimal?  @db.Decimal(5, 1)
  height_in               Decimal?  @db.Decimal(5, 1)
  ship_date               DateTime? @db.Timestamptz()
  voided                  Boolean   @default(false)
  voided_at               DateTime? @db.Timestamptz()
  created_at              DateTime  @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)
  order PosOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([order_id])
  @@index([tracking_number])
  @@map("pos_shipping_labels")
}

model PosPackagingType {
  id        String   @id @default(cuid())
  store_id  String
  name      String
  sku       String?
  length_in Decimal  @db.Decimal(5, 1)
  width_in  Decimal  @db.Decimal(5, 1)
  height_in Decimal  @db.Decimal(5, 1)
  material  String   @default("cardboard")
  weight_oz Int      @default(0)
  active    Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@map("pos_packaging_types")
}

// ============================================================
// AFTERROAR NETWORK
// ============================================================

model PosNetworkTournament {
  id                    String    @id @default(cuid())
  name                  String
  format                String?
  game                  String    @default("MTG")
  host_store_id         String
  starts_at             DateTime  @db.Timestamptz()
  ends_at               DateTime? @db.Timestamptz()
  entry_fee_cents       Int       @default(0)
  max_players_per_store Int?
  prize_pool_description String?
  status                String    @default("upcoming") // upcoming, active, completed, cancelled
  settings              Json      @default("{}")
  created_at            DateTime  @default(now()) @db.Timestamptz()

  host_store            PosStore  @relation(fields: [host_store_id], references: [id])
  participating_stores  PosNetworkTournamentStore[]

  @@index([status])
  @@map("pos_network_tournaments")
}

model PosNetworkTournamentStore {
  id                     String   @id @default(cuid())
  network_tournament_id  String
  store_id               String
  local_tournament_id    String?
  player_count           Int      @default(0)
  joined_at              DateTime @default(now()) @db.Timestamptz()

  network_tournament PosNetworkTournament @relation(fields: [network_tournament_id], references: [id], onDelete: Cascade)
  store              PosStore             @relation(fields: [store_id], references: [id])

  @@index([network_tournament_id])
  @@map("pos_network_tournament_stores")
}

model PosNetworkPlayerRating {
  id             String    @id @default(cuid())
  player_name    String
  customer_id    String?
  store_id       String
  game           String    @default("MTG")
  format         String?
  rating         Int       @default(1200)
  wins           Int       @default(0)
  losses         Int       @default(0)
  draws          Int       @default(0)
  events_played  Int       @default(0)
  last_played_at DateTime? @db.Timestamptz()
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id])

  @@index([game, format])
  @@index([store_id])
  @@map("pos_network_player_ratings")
}
