  event    PosEvent          @relation(fields: [event_id], references: [id], onDelete: Cascade)
  checkins PosEventCheckin[]
  tickets  PosEventTicket[]

  @@index([event_id])
  @@map("pos_event_ticket_tiers")
}

// ============================================================
// POS EVENT TICKET — the sold artifact, with QR-scannable serial
// ============================================================
// PosEventCheckin records "showed up at the door, paid at door."
// PosEventTicket records "bought a ticket (maybe in advance), state
// tracks whether it's been redeemed yet."
//
// Lifecycle: sold → redeemed (terminal happy path)
//                or refunded (terminal refund path)
//                or cancelled (event cancelled, auto-refund)
//
// Ticket serial is a printable/scannable string. We embed it in QR codes
// for door scanning. Format: "TKT-<base32>-<checksum>" (10–14 chars).
// Capacity enforcement happens at sale time on the tier's `sold` counter.
//
// Guest tickets (no customer_id) are allowed — anonymous walk-in pre-sale,
// gift purchases, etc. Email/name captured at sale time so we can re-send.
// ============================================================
model PosEventTicket {
  id                   String    @id @default(cuid())
  store_id             String
  event_id             String
  ticket_tier_id       String
  customer_id          String?
  /// Free-form identity for guest tickets (no customer_id). We capture this
  /// at sale time so the ticket can be re-sent / refund issued by name+email.
  guest_name           String?
  guest_email          String?
  guest_phone          String?
  /// Scannable serial. Unique per ticket. Encoded as QR for door check-in.
  serial               String    @unique
  status               String    @default("sold") // sold | redeemed | refunded | cancelled
  amount_paid_cents    Int       @default(0)
  /// Sale-side ledger entry (nullable for comp tickets and during refunds).
  ledger_entry_id      String?
  sold_at              DateTime  @default(now()) @db.Timestamptz()
  redeemed_at          DateTime? @db.Timestamptz()
  /// Staff who scanned/checked in this ticket.
  redeemed_by_staff_id String?
  refunded_at          DateTime? @db.Timestamptz()
  refund_amount_cents  Int?
  refund_reason        String?
  /// Used to mark the ticket as already converted into a check-in row.
  /// When redeemed, we also create a PosEventCheckin so the existing event
  /// reporting flows pick it up. This is the link.
  checkin_id           String?

  store             PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  event             PosEvent           @relation(fields: [event_id], references: [id], onDelete: Cascade)
  tier              PosEventTicketTier @relation(fields: [ticket_tier_id], references: [id])
  customer          PosCustomer?       @relation(fields: [customer_id], references: [id])
  redeemed_by_staff PosStaff?          @relation(fields: [redeemed_by_staff_id], references: [id])

  @@index([store_id])
  @@index([event_id])
  @@index([event_id, status])
  @@index([customer_id])
  @@index([ticket_tier_id])
  @@map("pos_event_tickets")
}

// ============================================================
// POS IMMUTABLE LEDGER
// ============================================================
model PosLedgerEntry {
  id                  String   @id @default(cuid())
  store_id            String
  type                String
  customer_id         String?
  staff_id            String?
  event_id            String?
  amount_cents        Int
  tip_cents           Int      @default(0)
  credit_amount_cents Int      @default(0)
