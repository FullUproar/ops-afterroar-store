// ============================================================
// POS GAME RESERVATIONS
// ============================================================
// Reservation queue for the lending library. When a customer wants a
// lendable game that's currently checked out (or just unavailable today),
// they can join the queue. Position is implicit by created_at.
//
// Lifecycle:
//   - active   → in queue, waiting for current copy to return
//   - notified → copy is back; staff has reached out (sms/email/in-store)
//   - claimed  → became a checkout (linked via claimed_checkout_id)
//   - released → customer gave up / no-show / staff released
//   - expired  → window passed without claim
// ============================================================
model PosGameReservation {
  id                      String    @id @default(cuid())
  store_id                String
  inventory_item_id       String
  customer_id             String
  staff_id                String?
  status                  String    @default("active") // active | notified | claimed | released | expired
  /// Free-text note from staff: "wants for Saturday", "first time customer", etc.
  notes                   String?
  /// Timestamp the customer was contacted that the copy is available.
  notified_at             DateTime? @db.Timestamptz()
  /// When notified, how long they have to come pick it up before the
  /// reservation auto-expires and the next person in queue is notified.
  notification_expires_at DateTime? @db.Timestamptz()
  /// When the reservation became a checkout (terminal state for the happy path).
  claimed_checkout_id     String?
  released_at             DateTime? @db.Timestamptz()
  release_reason          String?
  created_at              DateTime  @default(now()) @db.Timestamptz()
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)
  customer       PosCustomer      @relation(fields: [customer_id], references: [id])
  staff          PosStaff?        @relation(fields: [staff_id], references: [id])

  @@index([store_id])
  @@index([store_id, status])
  @@index([inventory_item_id, status, created_at])
  @@index([customer_id])
  @@map("pos_game_reservations")
}

