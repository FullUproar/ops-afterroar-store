// ============================================================
// AFTERROAR FEDERATION API
// Server-to-server API keys for cross-service calls.
// FU is one consumer; FLGS storefronts will be others.
// ============================================================

model ApiKey {
  id          String    @id @default(cuid())
  /// Display prefix shown in admin UIs. Format: ar_live_xxxxxxxx (8 chars after ar_live_)
  /// Full key is never stored — only the prefix + sha256 hash.
  keyPrefix   String    @unique
  /// SHA-256 hash of the full key. Lookup is by hash, not by prefix.
  keyHash     String    @unique
  name        String
  /// Permission scopes — array of strings like 'read:users', 'read:venues:inventory'.
  /// Scope checks happen in the API middleware before the route runs.
  scopes      String[]
  /// User who minted the key. Mostly informational — keys are tied to scopes, not a user identity.
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedBy   String?
  /// Usage counter (denormalized — exact source-of-truth is ApiUsageLog).
  /// Cheap monitoring badge in the admin UI.
  usageCount  Int       @default(0)

  usageLogs ApiUsageLog[]

  @@index([keyHash])
  @@index([createdById])
  @@index([revokedAt])
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String?
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  /// e.g. "/api/v1/users/lookup". Stored as raw path; do not include query string.
  endpoint  String
  method    String
  status    Int
  /// Latency in ms — request received → response sent.
  latencyMs Int
  /// Best-effort. Reads X-Forwarded-For first, falls back to remoteAddress.
  ip        String?
  /// Optional error code for fast filtering (e.g. "rate_limited", "scope_denied", "not_found").
  errorCode String?
  timestamp DateTime @default(now())

  @@index([timestamp(sort: Desc)])
  @@index([apiKeyId, timestamp(sort: Desc)])
  @@index([endpoint, timestamp(sort: Desc)])
  @@index([status, timestamp(sort: Desc)])
}

// ============================================================
// REGISTER EVENT LOG (R2 OFFLINE SYNC)
// Append-only log of register-side events pushed from each device.
// Replays into pos_* tables (sales → ledger, inventory decrement, etc.)
// or surfaces conflicts to /dashboard/reconciliation.
//
// See afterroar-mobile/docs/register-sync-architecture.md for the full
// architecture (Lamport clocks, idempotency, per-table conflict policies).
// ============================================================
model RegisterEvent {
  /// Client-generated UUID. Idempotency primary — a retry of the same
  /// event must be a no-op. Combined with deviceId in the unique
  /// constraint to guarantee no double-apply across devices.
  id String @id

  storeId  String
  /// Device identifier — typically a per-tablet UUID generated on first
  /// boot and persisted in Capacitor Preferences. Stable across app
  /// restarts; rotates only when the tablet's local data is wiped.
  deviceId String

  /// Lamport count for ordering. Each device increments per event.
  /// Server orders events by (lamport ASC, deviceId) when replaying.
  /// Wall clock is for humans; this is for causality.
  lamport Int

  /// Wall clock from the device when the event was created. Used for
  /// audit + display, NOT for ordering. Tablet clocks drift; trust
  /// Lamport for causality, this for "what time did the cashier ring
  /// this up."
  wallTime DateTime

  /// Event type — sale, return, credit_apply, loyalty_redeem, etc.
  /// Server has a per-type handler that mutates pos_* tables.
  type String

  /// Event-specific payload. Validated against per-type schema by the
  /// /api/sync endpoint. Free-form here so adding new event types
  /// doesn't require migrations.
  payload Json

  /// Server-side outcome: applied | conflict | duplicate | rejected.
  /// 'duplicate' means the (deviceId, id) pair was seen before — sync
  /// retries hit this and treat it as success.
  status String @default("applied")

  /// When `status='conflict'`, structured info about why and what to
  /// surface in the reconciliation queue.
  conflictData Json?

  /// When the server received and processed this event. Lags wallTime
  /// by however long the device was offline.
  receivedAt DateTime @default(now())

  /// FK to PosStore — store-scoped event log; cascade with store.
  store PosStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([deviceId, id], name: "RegisterEvent_idempotency")
  @@index([storeId, wallTime(sort: Desc)])
  @@index([storeId, status])
  @@index([storeId, deviceId, lamport])
  @@map("register_events")
}

// ============================================================
// REGISTER DEVICE — A paired register tablet (Passport-rooted)
// ============================================================
// A long-lived device-bound auth token, replacing the old "owner mints
// an API key and pastes it into the tablet" flow.
//
// Lifecycle:
//   1. Owner (a Passport user) is signed into Store Ops.
//   2. They generate a RegisterPairingCode (6 digits, expires in 10 min).
//   3. New tablet enters the code. Server creates a RegisterDevice row,
//      hashes a freshly-minted token (sha256), returns the plaintext token
//      ONCE in the pair-response. Tablet stores it locally and uses it as
//      the X-API-Key on all future register endpoints.
//   4. Revoked from /dashboard/devices or by removing the paired_by user.
//
// Authorization chain: device ← issued by → Passport user ← scoped to →
// store. Every register API call has a Passport identity behind it.
//
// Note: existing ApiKey-based register:write tokens still work (headless
// integrations / partner tools) — RegisterDevice is the human-facing path.
// ============================================================
model RegisterDevice {
  id            String    @id @default(cuid())
  store_id      String
  /// User.id of the Passport user who paired this device.
  paired_by     String
  /// Cashier-readable label: "Counter 1", "Mobile sale runner", "Mike's iPad".
  display_name  String
  /// sha256(plaintext_token). Plaintext is shown ONCE on pair, never stored.
  token_hash    String    @unique
  /// Stable per-tablet UUID generated by the device on first boot.
  device_id     String
  /// Capability summary — informational. The actual scope is "register:write"
  /// equivalent and is enforced at the middleware layer.
  scopes        String[]  @default(["register:write"])
  last_seen_at  DateTime?
  /// Ops-side inventory: e.g. android model + capacitor version, captured on pair.
  device_meta   Json?
  revoked_at    DateTime?
  /// Why it was revoked: 'manual' | 'staff_removed' | 'expired' | 'rotated'.
  revoke_reason String?
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz()

  store          PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)
  paired_by_user User     @relation(fields: [paired_by], references: [id])

  @@index([store_id])
  @@index([store_id, revoked_at])
  @@index([device_id])
  @@map("register_devices")
}

// ============================================================
// REGISTER PAIRING CODE — Short-lived, one-shot
// ============================================================
// 6-digit numeric code. Owner generates it from /dashboard/devices on a
// desktop browser, types it on the new tablet within 10 minutes.
//
// Codes are unique while alive (we generate-and-retry on collision).
// Once claimed, claimed_at + claimed_device_id are set and the code is
// rejected on subsequent uses. Expired codes are pruned by a periodic
// job (or just left to age out — the table is small).
// ============================================================
model RegisterPairingCode {
  /// 6 numeric digits. Primary key — fast lookup on the cashier-typing path.
  code              String    @id @db.VarChar(6)
  store_id          String
  /// User.id of the Passport user who generated this code.
  paired_by         String
  /// Optional pre-set name; if absent, the cashier names the device on pair.
  display_name      String?
  expires_at        DateTime  @db.Timestamptz()
  claimed_at        DateTime? @db.Timestamptz()
  /// Set when the code is consumed; FK to RegisterDevice.id.
  claimed_device_id String?
  created_at        DateTime  @default(now()) @db.Timestamptz()

  paired_by_user User @relation(fields: [paired_by], references: [id])

  @@index([store_id, expires_at])
  @@map("register_pairing_codes")
}
