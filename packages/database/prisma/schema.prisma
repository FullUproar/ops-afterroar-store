  store_id    String
  customer_id String
  staff_name  String?
  content     String
  created_at  DateTime @default(now()) @db.Timestamptz()

  store    PosStore    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id, created_at(sort: Desc)])
