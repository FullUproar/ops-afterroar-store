// ============================================================
// POS LOYALTY POINTS LEDGER
// ============================================================
model PosLoyaltyEntry {
  id            String   @id @default(cuid())
  store_id      String
  customer_id   String
  type          String // earn_purchase, earn_trade_in, earn_event, redeem, adjust
  points        Int // positive = earn, negative = redeem
  balance_after Int // running balance after this transaction
  description   String?
  reference_id  String? // ledger_entry_id, trade_in_id, event_id, etc.
  metadata      Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz()

  store    PosStore    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id])

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, created_at(sort: Desc)])
  @@map("pos_loyalty_entries")
}

// ============================================================
// POS INVENTORY
// ============================================================
model PosInventoryItem {
  id                        String   @id @default(cuid())
  store_id                  String
  name                      String
  category                  String
  sku                       String?
  barcode                   String?
  /// Alternate barcodes (publisher reprints with new UPCs, manufacturer pack
  /// codes, in-house labels). Lookups should query both `barcode` and this
  /// array. The primary `barcode` is kept for the existing index + display.
  barcodes                  String[] @default([])
  price_cents               Int      @default(0)
  cost_cents                Int      @default(0)
  /// Highest cost ever paid (or first cost — see metadata). Set on the first
  /// non-zero cost write and never overwritten thereafter. Used to show
  /// historical pricing context on the item edit form. Nullable so legacy
  /// rows that have never had a cost write stay null.
  first_cost_cents          Int?
  /// Most recently paid cost. Updated on every cost write. Mirrors `cost_cents`
  /// today but kept separate so we can wire `cost_cents` to the *current
  /// average cost* later without losing the most-recent-purchase signal.
  last_cost_cents           Int?
  quantity                  Int      @default(0)
  low_stock_threshold       Int      @default(5)
  attributes                Json     @default("{}")
  image_url                 String?
  external_id               String?
  supplier_id               String?
  lead_time_days            Int?
  reorder_point             Int?
  safety_stock              Int      @default(0)
  active                    Boolean  @default(true)
  lendable                  Boolean  @default(false)
  online_allocation         Int      @default(0) // qty allocated for online sale (pushed to Shopify)
  shopify_variant_id        String? // Shopify variant ID for sync
  shopify_inventory_item_id String? // Shopify inventory item ID for level sync
  created_at                DateTime @default(now()) @db.Timestamptz()
  updated_at                DateTime @default(now()) @db.Timestamptz()

  catalog_product_id String?
  shared_to_catalog  Boolean @default(false)

  /// Variant parent. When set, this row is a child variant of `parent_id`
  /// (e.g. "Pandemic Legacy Season 1 — Red Box"). Both parent and children
  /// can be sold; the relationship is for grouping in the catalog UI and
  /// sharing core metadata. Self-referential — null for stand-alone items.
  parent_id     String?
  /// Display label for the variant pick on the register (e.g. "Cover A",
  /// "Foil", "Season 1"). Free text, store-defined.
  variant_label String?

  weight_oz        Int?
  length_in        Decimal? @db.Decimal(5, 1)
  width_in         Decimal? @db.Decimal(5, 1)
  height_in        Decimal? @db.Decimal(5, 1)
  ships_separately Boolean  @default(false)

  ebay_listing_id String?
  ebay_offer_id   String?
  listed_on_ebay  Boolean @default(false)

  cardtrader_product_id String?
  listed_on_cardtrader  Boolean @default(false)

  manapool_listing_id String?
  listed_on_manapool  Boolean @default(false)

  oracle_id String?

  store                PosStore               @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier             PosSupplier?           @relation(fields: [supplier_id], references: [id])
  catalog_product      PosCatalogProduct?     @relation(fields: [catalog_product_id], references: [id])
  parent               PosInventoryItem?      @relation("InventoryVariants", fields: [parent_id], references: [id], onDelete: SetNull)
  variants             PosInventoryItem[]     @relation("InventoryVariants")
  trade_in_items       PosTradeInItem[]
  return_items         PosReturnItem[]
  inventory_levels     PosInventoryLevel[]
  game_checkouts       PosGameCheckout[]
  purchase_order_items PosPurchaseOrderItem[]
  stock_count_items    PosStockCountItem[]
  order_items          PosOrderItem[]
  consignment_items    PosConsignmentItem[]
  holds                PosInventoryHold[]
  cost_history         PosCostHistory[]
  vendor_links         PosVendorItem[]
  break_recipes_parent PosBreakRecipe[]       @relation("BreakRecipeParent")
  break_recipes_child  PosBreakRecipe[]       @relation("BreakRecipeChild")
  break_events_parent  PosBreakEvent[]        @relation("BreakEventParent")
  game_reservations    PosGameReservation[]
  menu_recipes         PosMenuRecipe[]
  pull_list_items      PosPullListItem[]

  @@index([store_id])
  @@index([store_id, active])
  @@index([store_id, category])
  @@index([barcode])
  @@index([store_id, sku])
  @@index([catalog_product_id])
  @@index([oracle_id])
  @@index([parent_id])
  @@map("pos_inventory_items")
}

// ============================================================
// POS PULL LIST — comic shop subscriber pull lists.
// ============================================================
// The killer comic-shop feature. Each PosPullList is a customer's standing
// subscription to a series; new issues that match get auto-allocated to
// their box on receive (or via the weekly "fulfill pulls" workflow).
//
// PosPullListItem is the per-issue allocation: when a new issue of the
// series arrives, an item is created with status='pending'. The shop
// notifies the customer via email/sms/in-store, customer picks up,
// item flips to 'fulfilled' (and converts to a sale).
//
// Future: Diamond/Lunar/PRH weekly catalog ingest will auto-create the
// pending allocations. Today, the shop creates them manually on receive.
// ============================================================
model PosPullList {
  id             String    @id @default(cuid())
  store_id       String
  customer_id    String
  /// Free-text series identifier — store-defined (e.g. "Saga", "The Department of Truth").
  /// Future: replace with PosCatalogProduct relation when ComicVine ingest exists.
  series_title   String
  /// Optional publisher filter (so "Saga" subscribers don't get an unrelated
  /// indie book that happens to share the title).
  publisher      String?
  /// Customer wants variant covers? (Cover B, ratio variants, etc.)
  wants_variants Boolean   @default(false)
  /// Hold capacity per issue (usually 1, but some collectors want 2 for
  /// reading-copy + bag-and-board copy).
  qty_per_issue  Int       @default(1)
  /// Notes from the cashier — "wants signed if available", "skip if Hickman", etc.
  notes          String?
  /// status: active | paused | cancelled
  status         String    @default("active")
  paused_at      DateTime? @db.Timestamptz()
  cancelled_at   DateTime? @db.Timestamptz()
  /// When the customer last picked up an issue.
  last_pickup_at DateTime? @db.Timestamptz()
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz()

  store    PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer       @relation(fields: [customer_id], references: [id])
  items    PosPullListItem[]

  @@index([store_id, status])
  @@index([customer_id])
  @@index([store_id, series_title])
  @@map("pos_pull_lists")
}

model PosPullListItem {
  id                String    @id @default(cuid())
  pull_list_id      String
  /// Optional link to the actual inventory item. Set on fulfill so the
  /// pickup converts cleanly to a sale.
  inventory_item_id String?
  issue_number      String
  variant_label     String?
  /// status: pending | held | fulfilled | skipped | expired
  status            String    @default("pending")
  notified_at       DateTime? @db.Timestamptz()
  held_at           DateTime? @db.Timestamptz()
  fulfilled_at      DateTime? @db.Timestamptz()
  ledger_entry_id   String?
  /// When the item auto-expires if not picked up. Default ~90 days.
  expires_at        DateTime? @db.Timestamptz()
  notes             String?
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz()

  pull_list      PosPullList       @relation(fields: [pull_list_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@index([pull_list_id])
  @@index([pull_list_id, status])
  @@index([inventory_item_id])
  @@map("pos_pull_list_items")
}

// ============================================================
// POS INTEGRATION STATUS — health tracking for the data
// integrations registry (lib/integrations/registry.ts).
// ============================================================
// One row per (store_id, integration_id). The integrations dashboard at
// /dashboard/integrations reads this to render status pills and last-tested
// timestamps. Adapters write here on every test-connection call.
//
// store_id = null is a platform-wide integration (Scryfall, BGG, etc. — no
// per-store config). store_id = X is a per-store integration where each
// store has its own API key/credentials (ComicVine, eBay, ManaPool).
// ============================================================
model PosIntegrationStatus {
  id              String    @id @default(cuid())
  store_id        String?
  /// Integration id from lib/integrations/registry.ts.
  integration_id  String
  /// "ok" | "degraded" | "down" | "unconfigured" | "untested"
  status          String    @default("untested")
  last_tested_at  DateTime? @db.Timestamptz()
  last_latency_ms Int?
  last_error      String?
  /// Per-store config blob (e.g. encrypted API key when configScope=per_store).
  /// Empty object for platform-wide integrations.
  config          Json      @default("{}")
  created_at      DateTime  @default(now()) @db.Timestamptz()
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamptz()

  store PosStore? @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, integration_id])
  @@index([integration_id])
  @@map("pos_integration_status")
}

model PosInventoryHold {
  id           String    @id @default(cuid())
  store_id     String
  item_id      String
  customer_id  String?
  staff_id     String
  /// Optional event link — when set, this hold reserves prize-pool inventory
  /// for an event/tournament. Released back to general stock if the event is
  /// cancelled, allocated to winners on event completion.
  event_id     String?
  quantity     Int       @default(1)
  reason       String? // "Customer request", "Phone order", "Prize pool", etc.
  status       String    @default("active") // active | fulfilled | released | expired
  held_at      DateTime  @default(now()) @db.Timestamptz()
  expires_at   DateTime  @db.Timestamptz()
  fulfilled_at DateTime? @db.Timestamptz()
  released_at  DateTime? @db.Timestamptz()

  store    PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  item     PosInventoryItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  customer PosCustomer?     @relation(fields: [customer_id], references: [id])
  staff    PosStaff         @relation(fields: [staff_id], references: [id])
  event    PosEvent?        @relation(fields: [event_id], references: [id], onDelete: SetNull)

  @@index([store_id, status])
  @@index([item_id, status])
  @@index([event_id])
  @@index([expires_at])
  @@map("pos_inventory_holds")
}

model PosSupplier {
  id                     String   @id @default(cuid())
  store_id               String
  name                   String
  contact                String?
  default_lead_time_days Int      @default(14)
  notes                  String?
  /// Optional account number / customer ID at this distributor (e.g. Alliance
  /// account #). Used as the "from" identifier on POs and helpful when the
  /// store has separate accounts at the same distributor.
  account_number         String?
  /// Free-form metadata: ordering URL, sales rep contact, payment terms, etc.
  metadata               Json     @default("{}")
  created_at             DateTime @default(now()) @db.Timestamptz()

  store           PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  items           PosInventoryItem[]
  purchase_orders PosPurchaseOrder[]
  vendor_items    PosVendorItem[]

  @@index([store_id])
  @@map("pos_suppliers")
}

/// Per-(supplier, item) link. Lets one inventory item carry SKUs from multiple
/// distributors (e.g. Alliance, ACD, GTS for the same board game), with one
/// flagged `preferred` so reorder defaults to it. Cost shown here is the most
/// recent cost from THAT vendor — distinct from PosInventoryItem.last_cost
/// which is the most recent cost from ANY vendor.
model PosVendorItem {
  id                String   @id @default(cuid())
  store_id          String
  supplier_id       String
  inventory_item_id String
  vendor_sku        String?
  case_pack         Int?
  last_cost_cents   Int?
  preferred         Boolean  @default(false)
  notes             String?
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @default(now()) @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier       PosSupplier      @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)

  @@unique([supplier_id, inventory_item_id])
  @@index([store_id])
  @@index([inventory_item_id])
  @@index([store_id, preferred])
  @@map("pos_vendor_items")
}

/// Cost history — one row per cost change on an inventory item. Sourced from
/// PO receipts, manual edits, or imports. Used to compute first/last/average
/// cost trends and to show the cost timeline on the item edit form.
model PosCostHistory {
  id                String   @id @default(cuid())
  store_id          String
  inventory_item_id String
  cost_cents        Int
  /// Source of the cost change: "po", "manual", "import", "trade_in"
  source            String
  /// Linking to a PO if source=po — soft reference (no FK so PO deletion
  /// doesn't cascade-delete history).
  purchase_order_id String?
  supplier_id       String?
  quantity          Int?
  note              String?
  staff_id          String?
  created_at        DateTime @default(now()) @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([inventory_item_id, created_at])
  @@map("pos_cost_history")
}

/// A reusable "break this into N of those" recipe. Used to convert a sealed
/// case into booster boxes, or a booster box into individual packs. Cost is
/// allocated proportionally on break (see /api/inventory/break).
model PosBreakRecipe {
  id                   String   @id @default(cuid())
  store_id             String
  parent_inventory_id  String
  child_inventory_id   String
  /// How many child units one parent unit produces (case → 6 boxes = 6).
  child_qty_per_parent Int
  /// Optional human-readable name (e.g. "Booster Box → Packs").
  name                 String?
  active               Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz()

  store  PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  parent PosInventoryItem @relation("BreakRecipeParent", fields: [parent_inventory_id], references: [id], onDelete: Cascade)
  child  PosInventoryItem @relation("BreakRecipeChild", fields: [child_inventory_id], references: [id], onDelete: Cascade)

  @@unique([parent_inventory_id, child_inventory_id])
  @@index([store_id])
  @@map("pos_break_recipes")
}

/// Audit trail of break operations performed. One row per break event.
model PosBreakEvent {
  id                  String   @id @default(cuid())
  store_id            String
  recipe_id           String?
  parent_inventory_id String
  parent_qty_consumed Int
  /// JSON array: [{ child_inventory_id, qty_added, unit_cost_cents }, ...]
  /// Stored denormalised so deletion of a child item doesn't break the audit
  /// trail. Use parent_id for the canonical FK; children are reference-only.
  children            Json     @default("[]")
  staff_id            String?
  note                String?
  created_at          DateTime @default(now()) @db.Timestamptz()

  store  PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  parent PosInventoryItem @relation("BreakEventParent", fields: [parent_inventory_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([store_id, created_at])
  @@map("pos_break_events")
}

// ============================================================
// POS EVENTS
// ============================================================
model PosEvent {
  id                 String    @id @default(cuid())
