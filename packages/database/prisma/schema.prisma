// ============================================================
// HQ BRIDGE OUTBOX
// ============================================================

model PosHqOutbox {
  id              Int       @id @default(autoincrement())
  idempotency_key String    @unique @default(uuid()) @db.Uuid
  store_id        String
  event_type      String    @db.VarChar(50)
  payload         Json
  status          String    @default("pending") @db.VarChar(20)
  retry_count     Int       @default(0)
  max_retries     Int       @default(5)
  next_retry_at   DateTime  @default(now()) @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  sent_at         DateTime? @db.Timestamptz()
  error_message   String?

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([status, next_retry_at])
  @@index([store_id, created_at(sort: Desc)])
  @@map("pos_hq_outbox")
}

// ============================================================
// CONSIGNMENT
// ============================================================

model PosConsignmentItem {
  id                     String    @id @default(cuid())
  store_id               String
  consignor_id           String
  inventory_item_id      String?
  asking_price_cents     Int
  commission_percent     Decimal   @default(15.00) @db.Decimal(5, 2)
  status                 String    @default("active") // active | sold | returned | expired
  listed_at              DateTime  @default(now()) @db.Timestamptz()
  sold_at                DateTime? @db.Timestamptz()
  payout_cents           Int?
  payout_ledger_entry_id String?
  notes                  String?

  store          PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  consignor      PosCustomer       @relation(fields: [consignor_id], references: [id])
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@index([store_id])
  @@index([consignor_id])
  @@index([store_id, status])
  @@map("pos_consignment_items")
}

// ============================================================
// CAFE / CONCESSIONS
// ============================================================

model PosTab {
  id                 String    @id @default(cuid())
  store_id           String
  customer_id        String?
  staff_id           String?
  event_id           String?
  table_label        String?
  status             String    @default("open") // open | closed | voided
  subtotal_cents     Int       @default(0)
  tax_cents          Int       @default(0)
  total_cents        Int       @default(0)
  ledger_entry_id    String?
  notes              String?
  table_fee_type     String? // flat | hourly | free_with_purchase
  table_fee_cents    Int       @default(0)
  table_fee_waived   Boolean   @default(false)
  age_verified       Boolean   @default(false)
  parent_tab_id      String?
  transferred_from   String?
  hold_type          String?   @default("cafe") // cafe | retail_park
  parked_by_staff_id String?
  parked_at          DateTime? @db.Timestamptz()
  opened_at          DateTime  @default(now()) @db.Timestamptz()
  closed_at          DateTime? @db.Timestamptz()

  store    PosStore     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer? @relation(fields: [customer_id], references: [id])
  event    PosEvent?    @relation(fields: [event_id], references: [id])
  items    PosTabItem[]

  @@index([store_id])
  @@index([store_id, status])
  @@index([store_id, hold_type, status])
  @@map("pos_tabs")
}

model PosTabItem {
  id                String    @id @default(cuid())
  tab_id            String
  name              String
  price_cents       Int
  quantity          Int       @default(1)
  modifiers         String?
  notes             String?
  status            String    @default("pending") // pending | in_progress | served
  item_type         String    @default("cafe") // cafe | retail | table_fee
  inventory_item_id String?
  /// Link to a managed menu item. When set, closing the tab triggers
  /// PosMenuRecipe-driven decrement of the linked ingredients (espresso →
  /// beans + cup + lid + milk). Tab items added from the hardcoded
  /// quick-add list don't have this set; only items added via the menu
  /// management surface do.
  menu_item_id      String?
  created_at        DateTime  @default(now()) @db.Timestamptz()
  served_at         DateTime? @db.Timestamptz()

  tab       PosTab       @relation(fields: [tab_id], references: [id], onDelete: Cascade)
  menu_item PosMenuItem? @relation(fields: [menu_item_id], references: [id])

  @@index([tab_id])
  @@index([menu_item_id])
  @@map("pos_tab_items")
}

model PosMenuItem {
  id             String    @id @default(cuid())
  store_id       String
  name           String
  category       String    @default("other") // drink | food | snack | alcohol | other
  price_cents    Int       @default(0)
  description    String?
  available      Boolean   @default(true)
  /// "86" list — temporary daily sold-out flag. Distinct from `available`,
  /// which is the permanent on/off menu state. When set, the item is hidden
  /// from the register today; cleared by midnight cron OR manual reset.
  sold_out_at    DateTime? @db.Timestamptz()
  sort_order     Int       @default(0)
  age_restricted Boolean   @default(false)
  /// Approximate prep time in seconds for the kitchen/barista. Optional.
  prep_seconds   Int?
  /// Free-form allergen flags and nutrition facts. Stored as JSON so adding
  /// new dietary flags doesn't require a migration. Common keys today:
  /// allergens (string[]), is_vegan, is_vegetarian, is_gluten_free, calories.
  dietary_info   Json      @default("{}")
  created_at     DateTime  @default(now()) @db.Timestamptz()

  store     PosStore        @relation(fields: [store_id], references: [id], onDelete: Cascade)
  recipes   PosMenuRecipe[]
  tab_items PosTabItem[]

  @@index([store_id])
  @@map("pos_menu_items")
}

/// Bill of materials: what inventory items get decremented when this menu
/// item sells. A latte → { espresso_beans: 18g (as 1 unit), 12oz_cup: 1, lid: 1, milk: 240ml }.
/// Quantities are stored as decimal so fractional units are honored.
model PosMenuRecipe {
  id                String   @id @default(cuid())
  menu_item_id      String
  inventory_item_id String
  /// How many units of the inventory item are consumed per one menu item sold.
  /// Example: a latte recipe might link 12oz_cup with quantity=1 and milk_carton
  /// with quantity=0.25 (one quarter of a carton).
  quantity_used     Decimal  @default(1) @db.Decimal(10, 3)
  /// Free-text role of this ingredient in the recipe. Optional.
  notes             String?
  created_at        DateTime @default(now()) @db.Timestamptz()

  menu_item      PosMenuItem      @relation(fields: [menu_item_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)

  @@unique([menu_item_id, inventory_item_id])
  @@index([menu_item_id])
  @@index([inventory_item_id])
  @@map("pos_menu_recipes")
}

model PosMenuModifier {
  id           String   @id @default(cuid())
  store_id     String
  name         String
  options      Json     @default("[]") // [{name, price_cents}]
  required     Boolean  @default(false)
  multi_select Boolean  @default(false)
  applies_to   String[] @default([])
  sort_order   Int      @default(0)

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@map("pos_menu_modifiers")
}

// ============================================================
// MOBILE REGISTER SESSIONS
// ============================================================

model PosMobileSession {
  id             String   @id @default(cuid())
  store_id       String
  staff_id       String?
  device_name    String?
  paired_at      DateTime @default(now()) @db.Timestamptz()
  expires_at     DateTime @db.Timestamptz()
  last_active_at DateTime @default(now()) @db.Timestamptz()
  tx_count       Int      @default(0)
  tx_total_cents Int      @default(0)
