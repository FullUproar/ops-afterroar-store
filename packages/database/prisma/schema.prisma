generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// HQ-OWNED: User table (READ-ONLY from Store Ops)
// Must match HQ's User model. Store Ops never writes to this.
// Only fields Store Ops needs are declared here.
// ============================================================
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  displayName     String?
  username        String?   @unique
  avatarUrl       String?
  passwordHash    String?
  passportCode    String?   @unique @db.VarChar(8)
  membershipTier  String    @default("FREE")
  gameLibrary     String?
  /// Standard NextAuth/email-verification timestamp. Set when the user clicks
  /// the verification link, OR when an OAuth provider that asserts a verified
  /// email (Google with email_verified=true) signs them in.
  emailVerified   DateTime?
  /// KYC-grade identity verification (Persona, ID.me) — separate from email.
  identityVerified Boolean  @default(false)
  reputationScore Int       @default(100)
  isFrozen        Boolean   @default(false)
  marketingConsent Boolean  @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  pos_staff    PosStaff[]
  accounts     Account[]
  consents     UserConsent[]
  pointsLedger PointsLedger[]
  activities   UserActivity[]
  gameLoans    GameLoan[]
  wishlistItems WishlistItem[]
  createdTags  GameTag[]
  badges       UserBadge[]
  entityMemberships EntityMember[]
  entityConsents    EntityConsent[]
  entityClaims      EntityClaim[]
  apiKeys      ApiKey[]
  paired_register_devices RegisterDevice[]
  generated_pairing_codes RegisterPairingCode[]

  @@map("User")
}

// ============================================================
// GAME TAG — Shared vocabulary for organizing collections.
// Like hashtags: anyone can create, popular ones gain meaning.
// ============================================================
// ============================================================
// PASSPORT BADGES — Portable identity markers. Native to Afterroar,
// also issuable by Full Uproar, stores, and other platform entities.
// ============================================================
// ============================================================
// AFTERROAR ENTITY � Canonical identity for stores, publishers,
// organizers, creators. Other apps (HQ, Store Ops) wrap with metadata.
// ============================================================
model AfterroarEntity {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  type         String    @default("store")
  /// Lifecycle: "unclaimed" (auto-imported from FLGS network DB, no owner
  /// has verified yet) → "pending" (claim submitted, awaiting verification)
  /// → "active" (claim verified, owner has access). "suspended" pulls the
  /// entity offline. Stored as string for flexibility — no DB enum.
  status       String    @default("pending")
  /// Nullable on unclaimed entities — bulk-imported FLGS data is often
  /// missing a public business email. The claim flow asks the claimant to
  /// provide one and uses that for verification email delivery.
  contactEmail String?
  contactName  String?
  contactPhone String?
  websiteUrl   String?
  logoUrl      String?
  description  String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?   @default("US")
  latitude     Float?
  longitude    Float?
  timezone     String?
  metadata     Json?     @default("{}")
  createdAt    DateTime  @default(now())
  approvedAt   DateTime?
  suspendedAt  DateTime?
  notes        String?

  members  EntityMember[]
  consents EntityConsent[]
  claims   EntityClaim[]

  @@index([type])
  @@index([status])
  @@index([city])
}

/// Audit + state for "I own this store, give me access" claim attempts.
/// One row per claim attempt; verified claims flip the entity to status=active
/// and create an EntityMember row with role=owner. Tokens are 64-char hex
/// strings sent via email; rotated on each new claim attempt for the same
/// entity to invalidate old links.
model EntityClaim {
  id           String   @id @default(cuid())
  entityId     String
  /// User initiating the claim (must be signed in to Passport).
  claimantUserId String
  /// Email the verification link was sent to. May differ from the user's
  /// primary email — e.g. owner uses owner@thestore.com to receive the link
  /// but is logged in as their personal Passport account.
  contactEmail String
  contactName  String?
  contactPhone String?
  /// Verification token (64 hex chars). Hashed at rest would be better for
  /// breach posture — leaving in plaintext for v1 to keep the link-redemption
  /// flow simple. Tokens expire 72h after creation; old tokens for the same
  /// entity are deleted when a new claim is initiated.
  token        String   @unique
  /// "pending" → "verified" → "rejected" / "expired".
  status       String   @default("pending")
  expiresAt    DateTime
  verifiedAt   DateTime?
  /// Free-form proof the claimant supplied (URLs, FEIN last 4, etc).
  /// Auto-verified if contactEmail's domain matches entity.websiteUrl.
  evidence     Json?    @default("{}")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  entity AfterroarEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [claimantUserId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([claimantUserId])
  @@index([status])
  @@index([token])
}

model EntityMember {
  id       String   @id @default(cuid())
  entityId String
  userId   String
  role     String   @default("member")
  addedAt  DateTime @default(now())
  addedBy  String?

  entity AfterroarEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
}

model EntityConsent {
  id         String    @id @default(cuid())
  userId     String
  entityId   String
  scopes     String[]
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  expiresAt  DateTime?
  source     String?

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity AfterroarEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  action      String
  targetType  String?
  targetId    String?
  entityId    String?
  scopesUsed  String[]
  metadata    Json?    @default("{}")
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([targetId])
  @@index([entityId])
  @@index([createdAt])
}

model ShopifyConnection {
  id              String    @id @default(cuid())
  entityId        String    @unique
  shopDomain      String    @unique
  accessToken     String
  scopes          String
  shopName        String?
  shopEmail       String?
  currency        String?
  pointsPerDollar Int       @default(1)
  minOrderCents   Int       @default(0)
  active          Boolean   @default(true)
  installedAt     DateTime  @default(now())
  uninstalledAt   DateTime?
  lastWebhookAt   DateTime?
  metadata        Json?     @default("{}")

  @@index([entityId])
  @@index([shopDomain])
  @@index([active])
}

model ShopifyWebhookEvent {
  id          String    @id @default(cuid())
  shopDomain  String
  topic       String
  eventId     String
  orderId     String?
  payload     Json
  processedAt DateTime?
  result      String?
  pointsDelta Int?
  userId      String?
  createdAt   DateTime  @default(now())

  @@unique([shopDomain, topic, eventId])
  @@index([shopDomain])
  @@index([topic])
  @@index([orderId])
  @@index([createdAt])
}

model ShopifyOauthState {
  state      String   @id
  shopDomain String
  entityId   String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}

model EntityConsentRequest {
  id              String    @id @default(cuid())
  token           String    @unique
  entityId        String
  requestedScopes String[]
  createdBy       String
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  claimedAt       DateTime?
  claimedByUserId String?
  note            String?

  @@index([entityId])
  @@index([token])
  @@index([expiresAt])
}

model PassportBadge {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  iconEmoji   String?
  iconUrl     String?
  color       String    @default("#FF8200")
  category    String    @default("general")
  issuerType  String    @default("afterroar")
  issuerName  String?
  issuerId    String?
  isLimited   Boolean   @default(false)
  totalIssued Int       @default(0)
  maxSupply   Int?
  createdAt   DateTime  @default(now())
  retiredAt   DateTime?

  userBadges UserBadge[]

  @@index([category])
  @@index([issuerType])
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeId   String
  issuedAt  DateTime  @default(now())
  issuedBy  String?
  reason    String?
  metadata  Json?     @default("{}")
  revokedAt DateTime?

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge PassportBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model GameTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  type      String   @default("custom")
  useCount  Int      @default(0)
  createdBy String?
  createdAt DateTime @default(now())
  creator   User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([type])
  @@index([useCount(sort: Desc)])
}

// ============================================================
// GAME LOAN — Track games lent to friends. User-owned data.
// "Who has my copy of Terraforming Mars?"
// ============================================================
model GameLoan {
  id           String    @id @default(cuid())
  userId       String
  gameTitle    String
  bggId        Int?
  borrowerName String
  borrowerContact String?
  lentAt       DateTime  @default(now())
  dueDate      DateTime?
  returnedAt   DateTime?
  condition    String?
  notes        String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, returnedAt])
}

// ============================================================
// WISHLIST ITEM — Games the user wants. Portable across stores.
// Shareable with non-gaming family for gift-giving.
// ============================================================
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  gameTitle String
  bggId     Int?
  priority  Int      @default(3)
  notes     String?
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameTitle])
  @@index([userId])
}

// ============================================================
// USER CONSENT — Granular per-category consent for the Afterroar
// consent architecture. Mirrors the table created by
// full-uproar-site migration 2026-04-12.
// ============================================================
model UserConsent {
  id        String    @id @default(cuid())
  userId    String
  category  String
  granted   Boolean
  grantedAt DateTime?
  revokedAt DateTime?
  source    String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@index([category])
}

// ============================================================
// POINTS LEDGER — Append-only ledger with running balance per store.
// Read view of the table owned by full-uproar-site. The afterroar
// app reads this to display points on the Passport.
// ============================================================
model PointsLedger {
  id          String    @id @default(cuid())
  userId      String
  storeId     String?
  amount      Int
  balance     Int
  action      String
  category    String
  description String
  metadata    String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, storeId])
  @@index([createdAt])
}

// ============================================================
// USER ACTIVITY — Activity log for check-ins, events, tournaments.
// Read view of the table owned by full-uproar-site.
// ============================================================
model UserActivity {
  id         Int      @id @default(autoincrement())
  userId     String
  action     String
  targetType String?
  targetId   Int?
  metadata   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, action])
}

// ============================================================
// VENUE — The federated store directory. Read view of the table
// owned by full-uproar-site. Used for /stores on afterroar.me.
// ============================================================
model Venue {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  status           String   @default("unclaimed")
  email            String?
  phone            String?
  website          String?
  address          String?
  city             String?
  state            String?
  zip              String?
  lat              Float?
  lng              Float?
  venueType        String?
  googleRating     Float?
  reviewCount      Int?
  description      String?
  shortDescription String?
  logoUrl          String?
  coverImageUrl    String?
  hours            String?
  amenities        String?
  /// Origin + extras. Crowdsourced rows carry { crowdsourced: true,
  /// suggested_by_user_id, suggested_at }. Bulk-imported rows carry
  /// { source: 'flgs_network_import', imported_at }. Free-form so
  /// downstream tools can attach analytics + provenance without schema
  /// churn.
  metadata         Json?    @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([city, state])
}

// NextAuth required models — these tables already exist in the shared
// Neon DB (created by the full-uproar-site schema). Declared here so
// the Prisma client can query them for PrismaAdapter.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// POS STORES
// ============================================================
model PosStore {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  owner_id   String?
  address    Json?
  settings   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()

  staff           PosStaff[]
  locations       PosLocation[]
  customers       PosCustomer[]
  inventory_items PosInventoryItem[]
  events          PosEvent[]
  ledger_entries  PosLedgerEntry[]
  trade_ins       PosTradeIn[]
  returns         PosReturn[]
  import_jobs     PosImportJob[]
  certifications  PosCertification[]
  promotions      PosPromotion[]
  loyalty_entries PosLoyaltyEntry[]
  preorders       PosPreorder[]
  gift_cards      PosGiftCard[]
  suppliers       PosSupplier[]
  game_checkouts  PosGameCheckout[]
  purchase_orders PosPurchaseOrder[]
  stock_counts    PosStockCount[]
  tournaments     PosTournament[]
  catalog_pricing PosCatalogPricing[]
  orders          PosOrder[]
  operational_logs PosOperationalLog[]
  mobile_sessions      PosMobileSession[]
  access_code_attempts PosAccessCodeAttempt[]
  customer_notes       PosCustomerNote[]
  allocation_pools     PosAllocationPool[]
  tabs                 PosTab[]
  consignment_items    PosConsignmentItem[]
  inventory_holds      PosInventoryHold[]
  menu_items           PosMenuItem[]
  menu_modifiers       PosMenuModifier[]
  hq_outbox            PosHqOutbox[]
  shipping_labels      PosShippingLabel[]
  packaging_types      PosPackagingType[]
  register_events      RegisterEvent[]
  hosted_network_tournaments  PosNetworkTournament[]
  network_tournament_entries  PosNetworkTournamentStore[]
  network_player_ratings      PosNetworkPlayerRating[]
  vendor_items                PosVendorItem[]
  cost_history                PosCostHistory[]
  break_recipes               PosBreakRecipe[]
  break_events                PosBreakEvent[]
  register_devices            RegisterDevice[]

  @@map("pos_stores")
}

// ============================================================
// HQ BRIDGE OUTBOX
// ============================================================

model PosHqOutbox {
  id              Int       @id @default(autoincrement())
  idempotency_key String    @unique @default(uuid()) @db.Uuid
  store_id        String
  event_type      String    @db.VarChar(50)
  payload         Json
  status          String    @default("pending") @db.VarChar(20)
  retry_count     Int       @default(0)
  max_retries     Int       @default(5)
  next_retry_at   DateTime  @default(now()) @db.Timestamptz()
  created_at      DateTime  @default(now()) @db.Timestamptz()
  sent_at         DateTime? @db.Timestamptz()
  error_message   String?

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([status, next_retry_at])
  @@index([store_id, created_at(sort: Desc)])
  @@map("pos_hq_outbox")
}

// ============================================================
// CONSIGNMENT
// ============================================================

model PosConsignmentItem {
  id                     String    @id @default(cuid())
  store_id               String
  consignor_id           String
  inventory_item_id      String?
  asking_price_cents     Int
  commission_percent     Decimal   @db.Decimal(5, 2) @default(15.00)
  status                 String    @default("active") // active | sold | returned | expired
  listed_at              DateTime  @default(now()) @db.Timestamptz()
  sold_at                DateTime? @db.Timestamptz()
  payout_cents           Int?
  payout_ledger_entry_id String?
  notes                  String?

  store              PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  consignor          PosCustomer       @relation(fields: [consignor_id], references: [id])
  inventory_item     PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@index([store_id])
  @@index([consignor_id])
  @@index([store_id, status])
  @@map("pos_consignment_items")
}

// ============================================================
// CAFE / CONCESSIONS
// ============================================================

model PosTab {
  id                String    @id @default(cuid())
  store_id          String
  customer_id       String?
  staff_id          String?
  event_id          String?
  table_label       String?
  status            String    @default("open") // open | closed | voided
  subtotal_cents    Int       @default(0)
  tax_cents         Int       @default(0)
  total_cents       Int       @default(0)
  ledger_entry_id   String?
  notes             String?
  table_fee_type    String?   // flat | hourly | free_with_purchase
  table_fee_cents   Int       @default(0)
  table_fee_waived  Boolean   @default(false)
  age_verified      Boolean   @default(false)
  parent_tab_id     String?
  transferred_from  String?
  hold_type         String?   @default("cafe") // cafe | retail_park
  parked_by_staff_id String?
  parked_at         DateTime? @db.Timestamptz()
  opened_at         DateTime  @default(now()) @db.Timestamptz()
  closed_at         DateTime? @db.Timestamptz()

  store    PosStore     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer? @relation(fields: [customer_id], references: [id])
  event    PosEvent?    @relation(fields: [event_id], references: [id])
  items    PosTabItem[]

  @@index([store_id])
  @@index([store_id, status])
  @@index([store_id, hold_type, status])
  @@map("pos_tabs")
}

model PosTabItem {
  id                String    @id @default(cuid())
  tab_id            String
  name              String
  price_cents       Int
  quantity          Int       @default(1)
  modifiers         String?
  notes             String?
  status            String    @default("pending") // pending | in_progress | served
  item_type         String    @default("cafe") // cafe | retail | table_fee
  inventory_item_id String?
  created_at        DateTime  @default(now()) @db.Timestamptz()
  served_at         DateTime? @db.Timestamptz()

  tab PosTab @relation(fields: [tab_id], references: [id], onDelete: Cascade)

  @@index([tab_id])
  @@map("pos_tab_items")
}

model PosMenuItem {
  id             String   @id @default(cuid())
  store_id       String
  name           String
  category       String   @default("other") // drink | food | snack | alcohol | other
  price_cents    Int      @default(0)
  description    String?
  available      Boolean  @default(true)
  sort_order     Int      @default(0)
  age_restricted Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@map("pos_menu_items")
}

model PosMenuModifier {
  id           String   @id @default(cuid())
  store_id     String
  name         String
  options      Json     @default("[]") // [{name, price_cents}]
  required     Boolean  @default(false)
  multi_select Boolean  @default(false)
  applies_to   String[] @default([])
  sort_order   Int      @default(0)

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@map("pos_menu_modifiers")
}

// ============================================================
// MOBILE REGISTER SESSIONS
// ============================================================

model PosMobileSession {
  id             String    @id @default(cuid())
  store_id       String
  staff_id       String?
  device_name    String?
  paired_at      DateTime  @default(now()) @db.Timestamptz()
  expires_at     DateTime  @db.Timestamptz()
  last_active_at DateTime  @default(now()) @db.Timestamptz()
  tx_count       Int       @default(0)
  tx_total_cents Int       @default(0)
  revoked        Boolean   @default(false)
  ip_address     String?
  user_agent     String?

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)
  staff PosStaff? @relation(fields: [staff_id], references: [id])

  @@index([store_id])
  @@index([store_id, revoked, expires_at])
  @@map("pos_mobile_sessions")
}

model PosAccessCodeAttempt {
  id           String   @id @default(cuid())
  store_id     String
  ip_address   String?
  attempted_at DateTime @default(now()) @db.Timestamptz()
  success      Boolean  @default(false)

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id, attempted_at(sort: Desc)])
  @@map("pos_access_code_attempts")
}

// ============================================================
// POS OPERATIONAL LOGS
// ============================================================
model PosOperationalLog {
  id          String   @id @default(cuid())
  store_id    String
  event_type  String
  severity    String   @default("info")
  message     String
  metadata    Json     @default("{}")
  user_id     String?
  staff_name  String?
  device_info String?
  created_at  DateTime @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id, created_at(sort: Desc)])
  @@index([store_id, event_type])
  @@index([store_id, severity])
  @@map("pos_operational_logs")
}

// ============================================================
// POS LOCATIONS (physical locations within a store/business)
// ============================================================
model PosLocation {
  id         String   @id @default(cuid())
  store_id   String
  name       String             // "Minneapolis Store", "Warehouse", "Display Case A"
  code       String?            // Short code: "MSP", "WH", "DC-A"
  type       String   @default("store") // "store", "warehouse", "display", "online"
  address    Json?
  phone      String?
  active     Boolean  @default(true)
  is_default Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()

  store            PosStore              @relation(fields: [store_id], references: [id], onDelete: Cascade)
  inventory_levels PosInventoryLevel[]
  transfers_from   PosTransfer[]         @relation("TransferFrom")
  transfers_to     PosTransfer[]         @relation("TransferTo")
  preorders        PosPreorder[]

  @@unique([store_id, code])
  @@index([store_id])
  @@map("pos_locations")
}

// ============================================================
// POS INVENTORY LEVELS (stock quantity per item per location)
// ============================================================
model PosInventoryLevel {
  id                String   @id @default(cuid())
  store_id          String
  inventory_item_id String
  location_id       String
  quantity          Int      @default(0)
  reserved_quantity Int      @default(0) // held for preorders/online
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @default(now()) @db.Timestamptz()

  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)
  location       PosLocation      @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@unique([inventory_item_id, location_id])
  @@index([store_id])
  @@index([location_id])
  @@map("pos_inventory_levels")
}

// ============================================================
// POS TRANSFERS (move stock between locations)
// ============================================================
model PosTransfer {
  id                String    @id @default(cuid())
  store_id          String
  from_location_id  String
  to_location_id    String
  staff_id          String?
  status            String    @default("pending") // pending, in_transit, completed, cancelled
  notes             String?
  items             Json      @default("[]") // [{inventory_item_id, quantity}]
  created_at        DateTime  @default(now()) @db.Timestamptz()
  completed_at      DateTime? @db.Timestamptz()

  from_location PosLocation @relation("TransferFrom", fields: [from_location_id], references: [id])
  to_location   PosLocation @relation("TransferTo", fields: [to_location_id], references: [id])

  @@index([store_id])
  @@map("pos_transfers")
}

// ============================================================
// POS PREORDERS
// ============================================================
model PosPreorder {
  id                String    @id @default(cuid())
  store_id          String
  customer_id       String?
  location_id       String?
  staff_id          String?
  status            String    @default("pending") // pending, confirmed, received, fulfilled, cancelled
  product_name      String
  product_details   Json      @default("{}") // set name, release date, variant info
  quantity          Int       @default(1)
  deposit_cents     Int       @default(0)
  total_price_cents Int       @default(0)
  notes             String?
  release_date      DateTime? @db.Timestamptz()
  fulfilled_at      DateTime? @db.Timestamptz()
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @db.Timestamptz()

  pool_id                 String?
  waitlisted              Boolean  @default(false)
  deposit_ledger_entry_id String?

  store    PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer?       @relation(fields: [customer_id], references: [id])
  location PosLocation?       @relation(fields: [location_id], references: [id])
  pool     PosAllocationPool? @relation(fields: [pool_id], references: [id])

  @@index([store_id])
  @@index([store_id, status])
  @@index([customer_id])
  @@map("pos_preorders")
}

model PosAllocationPool {
  id              String    @id @default(cuid())
  store_id        String
  product_name    String
  sku             String?
  total_allocated Int       @default(0)
  total_reserved  Int       @default(0)
  release_date    DateTime? @db.Date
  event_id        String?
  notes           String?
  status          String    @default("open") // open | closed | fulfilled
  created_at      DateTime  @default(now()) @db.Timestamptz()

  store     PosStore      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  event     PosEvent?     @relation(fields: [event_id], references: [id])
  preorders PosPreorder[]

  @@index([store_id])
  @@map("pos_allocation_pools")
}

// ============================================================
// POS STAFF (bridge: user_id → User.id)
// ============================================================
model PosStaff {
  id         String   @id @default(cuid())
  user_id    String
  store_id   String
  role       String   @default("cashier")
  name       String
  active     Boolean  @default(true)
  pin_hash           String?
  badge_code         String?
  invite_token       String?
  invite_expires_at  DateTime? @db.Timestamptz()
  invite_accepted_at DateTime? @db.Timestamptz()
  created_at         DateTime  @default(now()) @db.Timestamptz()

  user           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  ledger_entries PosLedgerEntry[]
  trade_ins       PosTradeIn[]
  returns         PosReturn[]
  import_jobs     PosImportJob[]
  certifications  PosCertification[]
  time_entries    PosTimeEntry[]
  game_checkouts  PosGameCheckout[]
  stock_counts     PosStockCount[]
  mobile_sessions  PosMobileSession[]
  inventory_holds  PosInventoryHold[]

  @@unique([user_id, store_id])
  @@map("pos_staff")
}

// ============================================================
// POS TIME CLOCK
// ============================================================
model PosTimeEntry {
  id                String    @id @default(cuid())
  store_id          String
  staff_id          String
  clock_in          DateTime  @db.Timestamptz()
  clock_out         DateTime? @db.Timestamptz()
  hours_worked      Decimal?  @db.Decimal(5, 2)
  notes             String?
  clock_in_lat      Float?
  clock_in_lng      Float?
  clock_in_location String?   // 'on_site' | 'remote' | 'no_gps'
  created_at        DateTime  @default(now()) @db.Timestamptz()

  staff PosStaff @relation(fields: [staff_id], references: [id])

  @@index([store_id])
  @@index([staff_id])
  @@index([store_id, clock_in(sort: Desc)])
  @@map("pos_time_entries")
}

// ============================================================
// POS CUSTOMERS
// ============================================================
model PosCustomer {
  id                   String   @id @default(cuid())
  store_id             String
  name                 String
  email                String?
  phone                String?
  credit_balance_cents Int      @default(0)
  loyalty_points       Int      @default(0)
  notes                String?
  afterroar_user_id    String?
  deleted_at           DateTime? @db.Timestamptz()
  deletion_requested   Boolean  @default(false)
  created_at           DateTime @default(now()) @db.Timestamptz()
  updated_at           DateTime @default(now()) @db.Timestamptz()

  store              PosStore               @relation(fields: [store_id], references: [id], onDelete: Cascade)
  ledger_entries     PosLedgerEntry[]
  trade_ins          PosTradeIn[]
  returns            PosReturn[]
  event_checkins     PosEventCheckin[]
  loyalty_entries    PosLoyaltyEntry[]
  preorders          PosPreorder[]
  game_checkouts     PosGameCheckout[]
  tournament_players PosTournamentPlayer[]
  orders             PosOrder[]
  tags               String[]             @default([])
  customer_notes     PosCustomerNote[]
  tabs               PosTab[]
  consignment_items  PosConsignmentItem[]
  inventory_holds    PosInventoryHold[]

  @@index([store_id])
  @@map("pos_customers")
}

model PosCustomerNote {
  id          String   @id @default(cuid())
  store_id    String
  customer_id String
  staff_name  String?
  content     String
  created_at  DateTime @default(now()) @db.Timestamptz()

  store    PosStore    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id, created_at(sort: Desc)])
  @@map("pos_customer_notes")
}

// ============================================================
// POS PROMOTIONS / SALE PRICING
// ============================================================
model PosPromotion {
  id             String    @id @default(cuid())
  store_id       String
  name           String
  type           String
  value          Int
  scope          String
  scope_value    String?
  starts_at      DateTime? @db.Timestamptz()
  ends_at        DateTime? @db.Timestamptz()
  active         Boolean   @default(true)
  priority       Int       @default(0)
  metadata       Json      @default("{}")
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([store_id, active])
  @@map("pos_promotions")
}

// ============================================================
// POS LOYALTY POINTS LEDGER
// ============================================================
model PosLoyaltyEntry {
  id           String   @id @default(cuid())
  store_id     String
  customer_id  String
  type         String            // earn_purchase, earn_trade_in, earn_event, redeem, adjust
  points       Int               // positive = earn, negative = redeem
  balance_after Int              // running balance after this transaction
  description  String?
  reference_id String?           // ledger_entry_id, trade_in_id, event_id, etc.
  metadata     Json     @default("{}")
  created_at   DateTime @default(now()) @db.Timestamptz()

  store    PosStore    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id])

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, created_at(sort: Desc)])
  @@map("pos_loyalty_entries")
}

// ============================================================
// POS INVENTORY
// ============================================================
model PosInventoryItem {
  id                  String   @id @default(cuid())
  store_id            String
  name                String
  category            String
  sku                 String?
  barcode             String?
  /// Alternate barcodes (publisher reprints with new UPCs, manufacturer pack
  /// codes, in-house labels). Lookups should query both `barcode` and this
  /// array. The primary `barcode` is kept for the existing index + display.
  barcodes            String[] @default([])
  price_cents         Int      @default(0)
  cost_cents          Int      @default(0)
  /// Highest cost ever paid (or first cost — see metadata). Set on the first
  /// non-zero cost write and never overwritten thereafter. Used to show
  /// historical pricing context on the item edit form. Nullable so legacy
  /// rows that have never had a cost write stay null.
  first_cost_cents    Int?
  /// Most recently paid cost. Updated on every cost write. Mirrors `cost_cents`
  /// today but kept separate so we can wire `cost_cents` to the *current
  /// average cost* later without losing the most-recent-purchase signal.
  last_cost_cents     Int?
  quantity            Int      @default(0)
  low_stock_threshold Int      @default(5)
  attributes          Json     @default("{}")
  image_url           String?
  external_id         String?
  supplier_id         String?
  lead_time_days      Int?
  reorder_point       Int?
  safety_stock        Int      @default(0)
  active              Boolean  @default(true)
  lendable            Boolean  @default(false)
  online_allocation   Int      @default(0)   // qty allocated for online sale (pushed to Shopify)
  shopify_variant_id  String?                // Shopify variant ID for sync
  shopify_inventory_item_id String?          // Shopify inventory item ID for level sync
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @db.Timestamptz()

  catalog_product_id  String?
  shared_to_catalog   Boolean  @default(false)

  /// Variant parent. When set, this row is a child variant of `parent_id`
  /// (e.g. "Pandemic Legacy Season 1 — Red Box"). Both parent and children
  /// can be sold; the relationship is for grouping in the catalog UI and
  /// sharing core metadata. Self-referential — null for stand-alone items.
  parent_id           String?
  /// Display label for the variant pick on the register (e.g. "Cover A",
  /// "Foil", "Season 1"). Free text, store-defined.
  variant_label       String?

  weight_oz           Int?
  length_in           Decimal? @db.Decimal(5, 1)
  width_in            Decimal? @db.Decimal(5, 1)
  height_in           Decimal? @db.Decimal(5, 1)
  ships_separately    Boolean  @default(false)

  ebay_listing_id     String?
  ebay_offer_id       String?
  listed_on_ebay      Boolean  @default(false)

  cardtrader_product_id String?
  listed_on_cardtrader  Boolean  @default(false)

  manapool_listing_id String?
  listed_on_manapool  Boolean  @default(false)

  oracle_id           String?

  store           PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier        PosSupplier?       @relation(fields: [supplier_id], references: [id])
  catalog_product PosCatalogProduct? @relation(fields: [catalog_product_id], references: [id])
  parent          PosInventoryItem?  @relation("InventoryVariants", fields: [parent_id], references: [id], onDelete: SetNull)
  variants        PosInventoryItem[] @relation("InventoryVariants")
  trade_in_items       PosTradeInItem[]
  return_items         PosReturnItem[]
  inventory_levels     PosInventoryLevel[]
  game_checkouts       PosGameCheckout[]
  purchase_order_items PosPurchaseOrderItem[]
  stock_count_items    PosStockCountItem[]
  order_items          PosOrderItem[]
  consignment_items    PosConsignmentItem[]
  holds                PosInventoryHold[]
  cost_history         PosCostHistory[]
  vendor_links         PosVendorItem[]
  break_recipes_parent PosBreakRecipe[]      @relation("BreakRecipeParent")
  break_recipes_child  PosBreakRecipe[]      @relation("BreakRecipeChild")
  break_events_parent  PosBreakEvent[]       @relation("BreakEventParent")

  @@index([store_id])
  @@index([store_id, active])
  @@index([store_id, category])
  @@index([barcode])
  @@index([store_id, sku])
  @@index([catalog_product_id])
  @@index([oracle_id])
  @@index([parent_id])
  @@map("pos_inventory_items")
}

model PosInventoryHold {
  id              String    @id @default(cuid())
  store_id        String
  item_id         String
  customer_id     String?
  staff_id        String
  quantity        Int       @default(1)
  reason          String?   // "Customer request", "Phone order", etc.
  status          String    @default("active") // active | fulfilled | released | expired
  held_at         DateTime  @default(now()) @db.Timestamptz()
  expires_at      DateTime  @db.Timestamptz()
  fulfilled_at    DateTime? @db.Timestamptz()
  released_at     DateTime? @db.Timestamptz()

  store    PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  item     PosInventoryItem @relation(fields: [item_id], references: [id], onDelete: Cascade)
  customer PosCustomer?     @relation(fields: [customer_id], references: [id])
  staff    PosStaff         @relation(fields: [staff_id], references: [id])

  @@index([store_id, status])
  @@index([item_id, status])
  @@index([expires_at])
  @@map("pos_inventory_holds")
}

model PosSupplier {
  id                     String   @id @default(cuid())
  store_id               String
  name                   String
  contact                String?
  default_lead_time_days Int      @default(14)
  notes                  String?
  /// Optional account number / customer ID at this distributor (e.g. Alliance
  /// account #). Used as the "from" identifier on POs and helpful when the
  /// store has separate accounts at the same distributor.
  account_number         String?
  /// Free-form metadata: ordering URL, sales rep contact, payment terms, etc.
  metadata               Json     @default("{}")
  created_at             DateTime @default(now()) @db.Timestamptz()

  store           PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  items           PosInventoryItem[]
  purchase_orders PosPurchaseOrder[]
  vendor_items    PosVendorItem[]

  @@index([store_id])
  @@map("pos_suppliers")
}

/// Per-(supplier, item) link. Lets one inventory item carry SKUs from multiple
/// distributors (e.g. Alliance, ACD, GTS for the same board game), with one
/// flagged `preferred` so reorder defaults to it. Cost shown here is the most
/// recent cost from THAT vendor — distinct from PosInventoryItem.last_cost
/// which is the most recent cost from ANY vendor.
model PosVendorItem {
  id                String   @id @default(cuid())
  store_id          String
  supplier_id       String
  inventory_item_id String
  vendor_sku        String?
  case_pack         Int?
  last_cost_cents   Int?
  preferred         Boolean  @default(false)
  notes             String?
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @default(now()) @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier       PosSupplier      @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)

  @@unique([supplier_id, inventory_item_id])
  @@index([store_id])
  @@index([inventory_item_id])
  @@index([store_id, preferred])
  @@map("pos_vendor_items")
}

/// Cost history — one row per cost change on an inventory item. Sourced from
/// PO receipts, manual edits, or imports. Used to compute first/last/average
/// cost trends and to show the cost timeline on the item edit form.
model PosCostHistory {
  id                String   @id @default(cuid())
  store_id          String
  inventory_item_id String
  cost_cents        Int
  /// Source of the cost change: "po", "manual", "import", "trade_in"
  source            String
  /// Linking to a PO if source=po — soft reference (no FK so PO deletion
  /// doesn't cascade-delete history).
  purchase_order_id String?
  supplier_id       String?
  quantity          Int?
  note              String?
  staff_id          String?
  created_at        DateTime @default(now()) @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([inventory_item_id, created_at])
  @@map("pos_cost_history")
}

/// A reusable "break this into N of those" recipe. Used to convert a sealed
/// case into booster boxes, or a booster box into individual packs. Cost is
/// allocated proportionally on break (see /api/inventory/break).
model PosBreakRecipe {
  id                  String   @id @default(cuid())
  store_id            String
  parent_inventory_id String
  child_inventory_id  String
  /// How many child units one parent unit produces (case → 6 boxes = 6).
  child_qty_per_parent Int
  /// Optional human-readable name (e.g. "Booster Box → Packs").
  name                String?
  active              Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz()

  store  PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  parent PosInventoryItem @relation("BreakRecipeParent", fields: [parent_inventory_id], references: [id], onDelete: Cascade)
  child  PosInventoryItem @relation("BreakRecipeChild", fields: [child_inventory_id], references: [id], onDelete: Cascade)

  @@unique([parent_inventory_id, child_inventory_id])
  @@index([store_id])
  @@map("pos_break_recipes")
}

/// Audit trail of break operations performed. One row per break event.
model PosBreakEvent {
  id                  String   @id @default(cuid())
  store_id            String
  recipe_id           String?
  parent_inventory_id String
  parent_qty_consumed Int
  /// JSON array: [{ child_inventory_id, qty_added, unit_cost_cents }, ...]
  /// Stored denormalised so deletion of a child item doesn't break the audit
  /// trail. Use parent_id for the canonical FK; children are reference-only.
  children            Json     @default("[]")
  staff_id            String?
  note                String?
  created_at          DateTime @default(now()) @db.Timestamptz()

  store  PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  parent PosInventoryItem @relation("BreakEventParent", fields: [parent_inventory_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([store_id, created_at])
  @@map("pos_break_events")
}

// ============================================================
// POS EVENTS
// ============================================================
model PosEvent {
  id                 String    @id @default(cuid())
  store_id           String
  name               String
  description        String?
  event_type         String?
  starts_at          DateTime  @db.Timestamptz()
  ends_at            DateTime? @db.Timestamptz()
  entry_fee_cents    Int       @default(0)
  max_players        Int?
  afterroar_event_id String?
  metadata           Json      @default("{}")
  created_at         DateTime  @default(now()) @db.Timestamptz()
  updated_at         DateTime  @default(now()) @db.Timestamptz()

  store          PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  checkins       PosEventCheckin[]
  ledger_entries PosLedgerEntry[]
  tournaments      PosTournament[]
  allocation_pools PosAllocationPool[]
  tabs             PosTab[]
  ticket_tiers     PosEventTicketTier[]

  @@index([store_id])
  @@index([store_id, starts_at(sort: Desc)])
  @@map("pos_events")
}

model PosEventCheckin {
  id                String   @id @default(cuid())
  event_id          String
  customer_id       String
  checked_in_at     DateTime @default(now()) @db.Timestamptz()
  fee_paid          Boolean  @default(false)
  ledger_entry_id   String?
  ticket_tier_id    String?
  amount_paid_cents Int      @default(0)

  event       PosEvent             @relation(fields: [event_id], references: [id], onDelete: Cascade)
  customer    PosCustomer          @relation(fields: [customer_id], references: [id])
  ticket_tier PosEventTicketTier?  @relation(fields: [ticket_tier_id], references: [id])

  @@unique([event_id, customer_id])
  @@map("pos_event_checkins")
}

model PosEventTicketTier {
  id              String    @id @default(cuid())
  event_id        String
  name            String
  description     String?
  price_cents     Int       @default(0)
  capacity        Int?
  sold            Int       @default(0)
  sort_order      Int       @default(0)
  available_from  DateTime? @db.Timestamptz()
  available_until DateTime? @db.Timestamptz()
  active          Boolean   @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz()

  event    PosEvent          @relation(fields: [event_id], references: [id], onDelete: Cascade)
  checkins PosEventCheckin[]

  @@index([event_id])
  @@map("pos_event_ticket_tiers")
}

// ============================================================
// POS IMMUTABLE LEDGER
// ============================================================
model PosLedgerEntry {
  id                  String   @id @default(cuid())
  store_id            String
  type                String
  customer_id         String?
  staff_id            String?
  event_id            String?
  amount_cents        Int
  tip_cents           Int      @default(0)
  credit_amount_cents Int      @default(0)
  description         String?
  metadata            Json     @default("{}")
  created_at          DateTime @default(now()) @db.Timestamptz()

  store            PosStore     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer         PosCustomer? @relation(fields: [customer_id], references: [id])
  staff            PosStaff?    @relation(fields: [staff_id], references: [id])
  event            PosEvent?    @relation(fields: [event_id], references: [id])
  returns_from_sale PosReturn[] @relation("OriginalSale")

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, type])
  @@index([store_id, created_at(sort: Desc)])
  @@index([event_id])
  @@map("pos_ledger_entries")
}

// ============================================================
// POS TRADE-INS
// ============================================================
model PosTradeIn {
  id                   String    @id @default(cuid())
  store_id             String
  customer_id          String?
  staff_id             String?
  status               String    @default("pending")
  payout_type          String?
  total_offer_cents    Int       @default(0)
  credit_bonus_percent Decimal   @default(0) @db.Decimal(5, 2)
  total_payout_cents   Int       @default(0)
  notes                String?
  ledger_entry_id      String?
  created_at           DateTime  @default(now()) @db.Timestamptz()
  completed_at         DateTime? @db.Timestamptz()

  store    PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer?     @relation(fields: [customer_id], references: [id])
  staff    PosStaff?        @relation(fields: [staff_id], references: [id])
  items    PosTradeInItem[]

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, status])
  @@map("pos_trade_ins")
}

model PosTradeInItem {
  id                 String   @id @default(cuid())
  trade_in_id        String
  inventory_item_id  String?
  name               String
  category           String?
  attributes         Json     @default("{}")
  quantity           Int      @default(1)
  market_price_cents Int?
  offer_price_cents  Int
  created_at         DateTime @default(now()) @db.Timestamptz()

  trade_in       PosTradeIn        @relation(fields: [trade_in_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@map("pos_trade_in_items")
}

// ============================================================
// POS RETURNS
// ============================================================
model PosReturn {
  id                       String   @id @default(cuid())
  store_id                 String
  customer_id              String?
  staff_id                 String?
  original_ledger_entry_id String
  status                   String   @default("completed")
