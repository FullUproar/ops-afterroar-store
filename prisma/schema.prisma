generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// HQ-OWNED: User table (READ-ONLY from Store Ops)
// Must match HQ's User model. Store Ops never writes to this.
// Only fields Store Ops needs are declared here.
// ============================================================
model User {
  id           String  @id
  email        String  @unique
  displayName  String?
  avatarUrl    String?
  passwordHash String?

  pos_staff PosStaff[]

  @@map("User")
}

// ============================================================
// POS STORES
// ============================================================
model PosStore {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  owner_id   String?
  address    Json?
  settings   Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()

  staff           PosStaff[]
  locations       PosLocation[]
  customers       PosCustomer[]
  inventory_items PosInventoryItem[]
  events          PosEvent[]
  ledger_entries  PosLedgerEntry[]
  trade_ins       PosTradeIn[]
  returns         PosReturn[]
  import_jobs     PosImportJob[]
  certifications  PosCertification[]
  promotions      PosPromotion[]
  loyalty_entries PosLoyaltyEntry[]
  preorders       PosPreorder[]
  gift_cards      PosGiftCard[]
  suppliers       PosSupplier[]
  game_checkouts  PosGameCheckout[]
  purchase_orders PosPurchaseOrder[]
  stock_counts    PosStockCount[]
  tournaments     PosTournament[]
  catalog_pricing PosCatalogPricing[]

  @@map("pos_stores")
}

// ============================================================
// POS LOCATIONS (physical locations within a store/business)
// ============================================================
model PosLocation {
  id         String   @id @default(cuid())
  store_id   String
  name       String             // "Minneapolis Store", "Warehouse", "Display Case A"
  code       String?            // Short code: "MSP", "WH", "DC-A"
  type       String   @default("store") // "store", "warehouse", "display", "online"
  address    Json?
  phone      String?
  active     Boolean  @default(true)
  is_default Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()

  store            PosStore              @relation(fields: [store_id], references: [id], onDelete: Cascade)
  inventory_levels PosInventoryLevel[]
  transfers_from   PosTransfer[]         @relation("TransferFrom")
  transfers_to     PosTransfer[]         @relation("TransferTo")
  preorders        PosPreorder[]

  @@unique([store_id, code])
  @@index([store_id])
  @@map("pos_locations")
}

// ============================================================
// POS INVENTORY LEVELS (stock quantity per item per location)
// ============================================================
model PosInventoryLevel {
  id                String   @id @default(cuid())
  store_id          String
  inventory_item_id String
  location_id       String
  quantity          Int      @default(0)
  reserved_quantity Int      @default(0) // held for preorders/online
  created_at        DateTime @default(now()) @db.Timestamptz()
  updated_at        DateTime @default(now()) @db.Timestamptz()

  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)
  location       PosLocation      @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@unique([inventory_item_id, location_id])
  @@index([store_id])
  @@index([location_id])
  @@map("pos_inventory_levels")
}

// ============================================================
// POS TRANSFERS (move stock between locations)
// ============================================================
model PosTransfer {
  id                String    @id @default(cuid())
  store_id          String
  from_location_id  String
  to_location_id    String
  staff_id          String?
  status            String    @default("pending") // pending, in_transit, completed, cancelled
  notes             String?
  items             Json      @default("[]") // [{inventory_item_id, quantity}]
  created_at        DateTime  @default(now()) @db.Timestamptz()
  completed_at      DateTime? @db.Timestamptz()

  from_location PosLocation @relation("TransferFrom", fields: [from_location_id], references: [id])
  to_location   PosLocation @relation("TransferTo", fields: [to_location_id], references: [id])

  @@index([store_id])
  @@map("pos_transfers")
}

// ============================================================
// POS PREORDERS
// ============================================================
model PosPreorder {
  id                String    @id @default(cuid())
  store_id          String
  customer_id       String?
  location_id       String?
  staff_id          String?
  status            String    @default("pending") // pending, confirmed, received, fulfilled, cancelled
  product_name      String
  product_details   Json      @default("{}") // set name, release date, variant info
  quantity          Int       @default(1)
  deposit_cents     Int       @default(0)
  total_price_cents Int       @default(0)
  notes             String?
  release_date      DateTime? @db.Timestamptz()
  fulfilled_at      DateTime? @db.Timestamptz()
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @db.Timestamptz()

  store    PosStore     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer? @relation(fields: [customer_id], references: [id])
  location PosLocation? @relation(fields: [location_id], references: [id])

  @@index([store_id])
  @@index([store_id, status])
  @@index([customer_id])
  @@map("pos_preorders")
}

// ============================================================
// POS STAFF (bridge: user_id → User.id)
// ============================================================
model PosStaff {
  id         String   @id @default(cuid())
  user_id    String
  store_id   String
  role       String   @default("cashier")
  name       String
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()

  user           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  ledger_entries PosLedgerEntry[]
  trade_ins       PosTradeIn[]
  returns         PosReturn[]
  import_jobs     PosImportJob[]
  certifications  PosCertification[]
  time_entries    PosTimeEntry[]
  game_checkouts  PosGameCheckout[]
  stock_counts    PosStockCount[]

  @@unique([user_id, store_id])
  @@map("pos_staff")
}

// ============================================================
// POS TIME CLOCK
// ============================================================
model PosTimeEntry {
  id           String    @id @default(cuid())
  store_id     String
  staff_id     String
  clock_in     DateTime  @db.Timestamptz()
  clock_out    DateTime? @db.Timestamptz()
  hours_worked Decimal?  @db.Decimal(5, 2)
  notes        String?
  created_at   DateTime  @default(now()) @db.Timestamptz()

  staff PosStaff @relation(fields: [staff_id], references: [id])

  @@index([store_id])
  @@index([staff_id])
  @@index([store_id, clock_in(sort: Desc)])
  @@map("pos_time_entries")
}

// ============================================================
// POS CUSTOMERS
// ============================================================
model PosCustomer {
  id                   String   @id @default(cuid())
  store_id             String
  name                 String
  email                String?
  phone                String?
  credit_balance_cents Int      @default(0)
  loyalty_points       Int      @default(0)
  notes                String?
  afterroar_user_id    String?
  created_at           DateTime @default(now()) @db.Timestamptz()
  updated_at           DateTime @default(now()) @db.Timestamptz()

  store              PosStore               @relation(fields: [store_id], references: [id], onDelete: Cascade)
  ledger_entries     PosLedgerEntry[]
  trade_ins          PosTradeIn[]
  returns            PosReturn[]
  event_checkins     PosEventCheckin[]
  loyalty_entries    PosLoyaltyEntry[]
  preorders          PosPreorder[]
  game_checkouts     PosGameCheckout[]
  tournament_players PosTournamentPlayer[]

  @@index([store_id])
  @@map("pos_customers")
}

// ============================================================
// POS PROMOTIONS / SALE PRICING
// ============================================================
model PosPromotion {
  id             String    @id @default(cuid())
  store_id       String
  name           String
  type           String
  value          Int
  scope          String
  scope_value    String?
  starts_at      DateTime? @db.Timestamptz()
  ends_at        DateTime? @db.Timestamptz()
  active         Boolean   @default(true)
  priority       Int       @default(0)
  metadata       Json      @default("{}")
  created_at     DateTime  @default(now()) @db.Timestamptz()
  updated_at     DateTime  @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id])
  @@index([store_id, active])
  @@map("pos_promotions")
}

// ============================================================
// POS LOYALTY POINTS LEDGER
// ============================================================
model PosLoyaltyEntry {
  id           String   @id @default(cuid())
  store_id     String
  customer_id  String
  type         String            // earn_purchase, earn_trade_in, earn_event, redeem, adjust
  points       Int               // positive = earn, negative = redeem
  balance_after Int              // running balance after this transaction
  description  String?
  reference_id String?           // ledger_entry_id, trade_in_id, event_id, etc.
  metadata     Json     @default("{}")
  created_at   DateTime @default(now()) @db.Timestamptz()

  store    PosStore    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id])

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, created_at(sort: Desc)])
  @@map("pos_loyalty_entries")
}

// ============================================================
// POS INVENTORY
// ============================================================
model PosInventoryItem {
  id                  String   @id @default(cuid())
  store_id            String
  name                String
  category            String
  sku                 String?
  barcode             String?
  price_cents         Int      @default(0)
  cost_cents          Int      @default(0)
  quantity            Int      @default(0)
  low_stock_threshold Int      @default(5)
  attributes          Json     @default("{}")
  image_url           String?
  external_id         String?
  supplier_id         String?
  lead_time_days      Int?
  reorder_point       Int?
  safety_stock        Int      @default(0)
  active              Boolean  @default(true)
  lendable            Boolean  @default(false)
  created_at          DateTime @default(now()) @db.Timestamptz()
  updated_at          DateTime @default(now()) @db.Timestamptz()

  catalog_product_id  String?
  shared_to_catalog   Boolean  @default(false)

  store           PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier        PosSupplier?       @relation(fields: [supplier_id], references: [id])
  catalog_product PosCatalogProduct? @relation(fields: [catalog_product_id], references: [id])
  trade_in_items       PosTradeInItem[]
  return_items         PosReturnItem[]
  inventory_levels     PosInventoryLevel[]
  game_checkouts       PosGameCheckout[]
  purchase_order_items PosPurchaseOrderItem[]
  stock_count_items    PosStockCountItem[]

  @@index([store_id])
  @@index([store_id, active])
  @@index([store_id, category])
  @@index([barcode])
  @@index([store_id, sku])
  @@index([catalog_product_id])
  @@map("pos_inventory_items")
}

model PosSupplier {
  id                     String   @id @default(cuid())
  store_id               String
  name                   String
  contact                String?
  default_lead_time_days Int      @default(14)
  notes                  String?
  created_at             DateTime @default(now()) @db.Timestamptz()

  store           PosStore           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  items           PosInventoryItem[]
  purchase_orders PosPurchaseOrder[]

  @@map("pos_suppliers")
}

// ============================================================
// POS EVENTS
// ============================================================
model PosEvent {
  id                 String    @id @default(cuid())
  store_id           String
  name               String
  description        String?
  event_type         String?
  starts_at          DateTime  @db.Timestamptz()
  ends_at            DateTime? @db.Timestamptz()
  entry_fee_cents    Int       @default(0)
  max_players        Int?
  afterroar_event_id String?
  metadata           Json      @default("{}")
  created_at         DateTime  @default(now()) @db.Timestamptz()
  updated_at         DateTime  @default(now()) @db.Timestamptz()

  store          PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  checkins       PosEventCheckin[]
  ledger_entries PosLedgerEntry[]
  tournaments    PosTournament[]

  @@index([store_id])
  @@index([store_id, starts_at(sort: Desc)])
  @@map("pos_events")
}

model PosEventCheckin {
  id              String   @id @default(cuid())
  event_id        String
  customer_id     String
  checked_in_at   DateTime @default(now()) @db.Timestamptz()
  fee_paid        Boolean  @default(false)
  ledger_entry_id String?

  event    PosEvent    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  customer PosCustomer @relation(fields: [customer_id], references: [id])

  @@unique([event_id, customer_id])
  @@map("pos_event_checkins")
}

// ============================================================
// POS IMMUTABLE LEDGER
// ============================================================
model PosLedgerEntry {
  id                  String   @id @default(cuid())
  store_id            String
  type                String
  customer_id         String?
  staff_id            String?
  event_id            String?
  amount_cents        Int
  credit_amount_cents Int      @default(0)
  description         String?
  metadata            Json     @default("{}")
  created_at          DateTime @default(now()) @db.Timestamptz()

  store            PosStore     @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer         PosCustomer? @relation(fields: [customer_id], references: [id])
  staff            PosStaff?    @relation(fields: [staff_id], references: [id])
  event            PosEvent?    @relation(fields: [event_id], references: [id])
  returns_from_sale PosReturn[] @relation("OriginalSale")

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, type])
  @@index([store_id, created_at(sort: Desc)])
  @@index([event_id])
  @@map("pos_ledger_entries")
}

// ============================================================
// POS TRADE-INS
// ============================================================
model PosTradeIn {
  id                   String    @id @default(cuid())
  store_id             String
  customer_id          String?
  staff_id             String?
  status               String    @default("pending")
  payout_type          String?
  total_offer_cents    Int       @default(0)
  credit_bonus_percent Decimal   @default(0) @db.Decimal(5, 2)
  total_payout_cents   Int       @default(0)
  notes                String?
  ledger_entry_id      String?
  created_at           DateTime  @default(now()) @db.Timestamptz()
  completed_at         DateTime? @db.Timestamptz()

  store    PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer PosCustomer?     @relation(fields: [customer_id], references: [id])
  staff    PosStaff?        @relation(fields: [staff_id], references: [id])
  items    PosTradeInItem[]

  @@index([store_id])
  @@index([customer_id])
  @@index([store_id, status])
  @@map("pos_trade_ins")
}

model PosTradeInItem {
  id                 String   @id @default(cuid())
  trade_in_id        String
  inventory_item_id  String?
  name               String
  category           String?
  attributes         Json     @default("{}")
  quantity           Int      @default(1)
  market_price_cents Int?
  offer_price_cents  Int
  created_at         DateTime @default(now()) @db.Timestamptz()

  trade_in       PosTradeIn        @relation(fields: [trade_in_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@map("pos_trade_in_items")
}

// ============================================================
// POS RETURNS
// ============================================================
model PosReturn {
  id                       String   @id @default(cuid())
  store_id                 String
  customer_id              String?
  staff_id                 String?
  original_ledger_entry_id String
  status                   String   @default("completed")
  refund_method            String
  reason                   String
  reason_notes             String?
  subtotal_cents           Int      @default(0)
  restocking_fee_cents     Int      @default(0)
  refund_amount_cents      Int      @default(0)
  credit_bonus_percent     Decimal  @default(0) @db.Decimal(5, 2)
  total_refund_cents       Int      @default(0)
  ledger_entry_id          String?
  created_at               DateTime @default(now()) @db.Timestamptz()

  store           PosStore        @relation(fields: [store_id], references: [id], onDelete: Cascade)
  customer        PosCustomer?    @relation(fields: [customer_id], references: [id])
  staff           PosStaff?       @relation(fields: [staff_id], references: [id])
  original_ledger PosLedgerEntry  @relation("OriginalSale", fields: [original_ledger_entry_id], references: [id])
  items           PosReturnItem[]

  @@index([store_id])
  @@index([customer_id])
  @@index([original_ledger_entry_id])
  @@map("pos_returns")
}

model PosReturnItem {
  id                String   @id @default(cuid())
  return_id         String
  inventory_item_id String?
  name              String
  category          String?
  quantity          Int      @default(1)
  price_cents       Int
  total_cents       Int
  restock           Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz()

  return_record  PosReturn         @relation(fields: [return_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@map("pos_return_items")
}

// ============================================================
// POS IMPORT JOBS
// ============================================================
model PosImportJob {
  id                String    @id @default(cuid())
  store_id          String
  staff_id          String
  source_system     String
  entity_type       String
  status            String    @default("draft")
  file_name         String
  file_hash         String
  row_count         Int       @default(0)
  field_mapping     Json      @default("{}")
  validation_errors Json      @default("[]")
  preview_data      Json      @default("[]")
  dry_run_summary   Json?
  committed_at      DateTime? @db.Timestamptz()
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @db.Timestamptz()

  store   PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  staff   PosStaff         @relation(fields: [staff_id], references: [id])
  records PosImportRecord[]

  @@index([store_id])
  @@index([store_id, file_hash])
  @@map("pos_import_jobs")
}

model PosImportRecord {
  id            String   @id @default(cuid())
  import_job_id String
  row_number    Int
  source_data   Json
  mapped_data   Json
  target_table  String
  target_id     String?
  status        String   @default("pending")
  error_message String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  import_job PosImportJob @relation(fields: [import_job_id], references: [id], onDelete: Cascade)

  @@index([import_job_id])
  @@map("pos_import_records")
}

// ============================================================
// POS DATA CERTIFICATION
// ============================================================
model PosCertification {
  id           String    @id @default(cuid())
  store_id     String
  staff_id     String
  status       String    @default("running")
  checks       Json      @default("[]")
  summary      Json?
  started_at   DateTime  @default(now()) @db.Timestamptz()
  completed_at DateTime? @db.Timestamptz()
  created_at   DateTime  @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)
  staff PosStaff @relation(fields: [staff_id], references: [id])

  @@index([store_id])
  @@map("pos_certifications")
}

// ============================================================
// POS GIFT CARDS
// ============================================================
model PosGiftCard {
  id                       String   @id @default(cuid())
  store_id                 String
  code                     String   @unique
  balance_cents            Int      @default(0)
  initial_balance_cents    Int      @default(0)
  purchased_by_customer_id String?
  active                   Boolean  @default(true)
  created_at               DateTime @default(now()) @db.Timestamptz()
  updated_at               DateTime @default(now()) @db.Timestamptz()

  store PosStore @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@map("pos_gift_cards")
}

// ============================================================
// POS GAME CHECKOUTS (lending/rental tracking)
// ============================================================
model PosGameCheckout {
  id                String    @id @default(cuid())
  store_id          String
  inventory_item_id String
  customer_id       String?
  staff_id          String?
  table_number      String?
  checked_out_at    DateTime  @default(now()) @db.Timestamptz()
  expected_return_at DateTime? @db.Timestamptz()
  returned_at       DateTime? @db.Timestamptz()
  return_condition  String?
  return_notes      String?
  status            String    @default("out") // out, returned, overdue
  created_at        DateTime  @default(now()) @db.Timestamptz()

  store          PosStore         @relation(fields: [store_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id])
  customer       PosCustomer?     @relation(fields: [customer_id], references: [id])
  staff          PosStaff?        @relation(fields: [staff_id], references: [id])

  @@index([store_id])
  @@index([store_id, status])
  @@index([inventory_item_id])
  @@map("pos_game_checkouts")
}

// ============================================================
// POS PURCHASE ORDERS
// ============================================================
model PosPurchaseOrder {
  id                String    @id @default(cuid())
  store_id          String
  supplier_id       String?
  supplier_name     String
  status            String    @default("draft")
  order_date        DateTime  @default(now()) @db.Timestamptz()
  expected_delivery DateTime? @db.Timestamptz()
  total_cost_cents  Int       @default(0)
  notes             String?
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @db.Timestamptz()

  store    PosStore                @relation(fields: [store_id], references: [id], onDelete: Cascade)
  supplier PosSupplier?            @relation(fields: [supplier_id], references: [id])
  items    PosPurchaseOrderItem[]

  @@index([store_id])
  @@index([store_id, status])
  @@map("pos_purchase_orders")
}

model PosPurchaseOrderItem {
  id                String   @id @default(cuid())
  purchase_order_id String
  inventory_item_id String?
  name              String
  sku               String?
  quantity_ordered  Int
  quantity_received Int      @default(0)
  cost_cents        Int
  created_at        DateTime @default(now()) @db.Timestamptz()

  purchase_order PosPurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem? @relation(fields: [inventory_item_id], references: [id])

  @@map("pos_purchase_order_items")
}

// ============================================================
// POS STOCK COUNTS
// ============================================================
model PosStockCount {
  id              String    @id @default(cuid())
  store_id        String
  staff_id        String?
  status          String    @default("in_progress")
  category_filter String?
  location_filter String?
  started_at      DateTime  @default(now()) @db.Timestamptz()
  completed_at    DateTime? @db.Timestamptz()
  total_items     Int       @default(0)
  variances       Int       @default(0)
  notes           String?

  store PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)
  staff PosStaff?         @relation(fields: [staff_id], references: [id])
  items PosStockCountItem[]

  @@index([store_id])
  @@map("pos_stock_counts")
}

model PosStockCountItem {
  id                String    @id @default(cuid())
  stock_count_id    String
  inventory_item_id String
  system_quantity   Int
  counted_quantity  Int?
  variance          Int?
  counted_at        DateTime? @db.Timestamptz()
  notes             String?

  stock_count    PosStockCount    @relation(fields: [stock_count_id], references: [id], onDelete: Cascade)
  inventory_item PosInventoryItem @relation(fields: [inventory_item_id], references: [id])

  @@map("pos_stock_count_items")
}

// ============================================================
// POS TOURNAMENTS
// ============================================================
model PosTournament {
  id            String   @id @default(cuid())
  store_id      String
  event_id      String?
  name          String
  format        String?
  status        String   @default("registration")
  bracket_type  String   @default("single_elimination")
  max_players   Int?
  current_round Int      @default(0)
  total_rounds  Int?
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @default(now()) @db.Timestamptz()

  store   PosStore              @relation(fields: [store_id], references: [id], onDelete: Cascade)
  event   PosEvent?             @relation(fields: [event_id], references: [id])
  players PosTournamentPlayer[]
  matches PosTournamentMatch[]

  @@index([store_id])
  @@index([event_id])
  @@map("pos_tournaments")
}

model PosTournamentPlayer {
  id            String   @id @default(cuid())
  tournament_id String
  customer_id   String?
  player_name   String
  seed          Int?
  wins          Int      @default(0)
  losses        Int      @default(0)
  draws         Int      @default(0)
  dropped       Boolean  @default(false)
  standing      Int?
  created_at    DateTime @default(now()) @db.Timestamptz()

  tournament      PosTournament       @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  customer        PosCustomer?        @relation(fields: [customer_id], references: [id])
  matches_as_p1   PosTournamentMatch[] @relation("MatchPlayer1")
  matches_as_p2   PosTournamentMatch[] @relation("MatchPlayer2")
  matches_won     PosTournamentMatch[] @relation("MatchWinner")

  @@map("pos_tournament_players")
}

model PosTournamentMatch {
  id            String   @id @default(cuid())
  tournament_id String
  round_number  Int
  match_number  Int
  player1_id    String?
  player2_id    String?
  winner_id     String?
  player1_score Int      @default(0)
  player2_score Int      @default(0)
  status        String   @default("pending")
  table_number  String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  tournament PosTournament        @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  player1    PosTournamentPlayer? @relation("MatchPlayer1", fields: [player1_id], references: [id])
  player2    PosTournamentPlayer? @relation("MatchPlayer2", fields: [player2_id], references: [id])
  winner     PosTournamentPlayer? @relation("MatchWinner", fields: [winner_id], references: [id])

  @@map("pos_tournament_matches")
}

// ============================================================
// POS CATALOG: Federated Product Catalog
// ============================================================
model PosCatalogProduct {
  id                    String   @id @default(cuid())
  name                  String
  category              String
  subcategory           String?
  game                  String?
  product_type          String?
  set_name              String?
  set_code              String?
  attributes            Json     @default("{}")
  external_ids          Json     @default("{}")
  image_url             String?
  description           String?
  contributed_by_store_id String?
  verified              Boolean  @default(false)
  created_at            DateTime @default(now()) @db.Timestamptz()
  updated_at            DateTime @default(now()) @db.Timestamptz()

  inventory_items PosInventoryItem[]
  pricing         PosCatalogPricing[]

  @@index([category])
  @@index([game])
  @@map("pos_catalog_products")
}

model PosCatalogCategory {
  id            String   @id @default(cuid())
  name          String
  slug          String
  parent_id     String?
  icon          String?
  sort_order    Int      @default(0)
  level         Int      @default(0)
  product_count Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz()

  parent   PosCatalogCategory?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children PosCatalogCategory[] @relation("CategoryTree")

  @@index([parent_id])
  @@index([slug])
  @@map("pos_catalog_categories")
}

model PosCatalogPricing {
  id                   String    @id @default(cuid())
  catalog_product_id   String
  store_id             String
  last_sale_price_cents Int?
  last_sale_date       DateTime? @db.Timestamptz()
  avg_sale_price_cents Int?
  velocity_per_week    Decimal   @default(0) @db.Decimal(10, 2)
  updated_at           DateTime  @default(now()) @db.Timestamptz()

  catalog_product PosCatalogProduct @relation(fields: [catalog_product_id], references: [id], onDelete: Cascade)
  store           PosStore          @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([catalog_product_id, store_id])
  @@map("pos_catalog_pricing")
}
